# ============================================
# WhatsApp SaaS - Variáveis de Ambiente
# ============================================
# 
# IMPORTANTE: Este arquivo contém APENAS exemplos.
# NÃO use estes valores em produção!
# 
# Copie este arquivo para .env e configure seus valores.
# ============================================

# ============================================
# 🔧 DESENVOLVIMENTO LOCAL
# ============================================
# Use estas configurações apenas para desenvolvimento local
# com Docker Compose ou serviços rodando na máquina.

NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/whatsapp_saas

# Redis (desenvolvimento local - SEM autenticação)
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

# ============================================
# 🚀 PRODUÇÃO (Railway / Heroku / VPS)
# ============================================
# Em produção, configure as variáveis abaixo.
# NUNCA use localhost ou 127.0.0.1 em produção!

# --- RAILWAY ---
# O plugin Redis do Railway fornece automaticamente:
# - REDIS_URL (URL completa - USE ESTA!)
# - REDISHOST, REDISPORT, REDISPASSWORD
#
# Apenas configure:
# REDIS_URL=${REDIS_URL}   # Usa a variável do Railway

# --- DOCKER COMPOSE PRODUÇÃO ---
# Configure REDIS_PASSWORD no .env e o docker-compose
# montará a URL automaticamente.
# REDIS_PASSWORD=sua-senha-segura

# --- VPS / OUTROS PROVEDORES ---
# REDIS_URL=redis://user:password@seu-host-redis:6379
# ou
# REDIS_HOST=seu-host-redis
# REDIS_PORT=6379
# REDIS_PASSWORD=sua-senha

# --- FALLBACK (opcional) ---
# Usado apenas se nenhuma outra variável estiver configurada
# REDIS_FALLBACK_URL=redis://user:password@fallback-host:6379

# ============================================
# 🛡️ RATE LIMIT (Auth) + ABUSE
# ============================================
# Os endpoints de autenticação possuem rate limit.
# - Recomendado em produção: configurar REDIS_URL (rate limit distribuído + filas).
# - Se Redis estiver indisponível, o backend usa fallback local (por processo)
#   e loga WARN claro. Isso evita abuso óbvio, mas NÃO substitui Redis em escala.

# ============================================
# 🔐 AUTENTICAÇÃO
# ============================================
# OBRIGATÓRIO em produção!
JWT_SECRET=ALTERE-ESTA-CHAVE-EM-PRODUCAO
# JWT_EXPIRES_IN=30m

# ============================================
# 🌐 URLs DA APLICAÇÃO
# ============================================
FRONTEND_URL=http://localhost:3000
# Em produção: FRONTEND_URL=https://seu-dominio.com

# ============================================
# 🔐 AUTH (NextAuth - Frontend)
# ============================================
# IMPORTANTE: NEXTAUTH_URL/AUTH_URL deve ser a BASE do frontend.
# NÃO inclua "/auth" ou "/api/auth".
# Ex.: https://seu-dominio.com
NEXTAUTH_URL=http://localhost:3000
# AUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me

# Backend URL (server-side) para o NextAuth sincronizar /auth/oauth
# Em docker-compose, use http://backend:3001
BACKEND_URL=http://localhost:3001

# Google Sign-In (Google Identity Services)
# O botão do navegador usa NEXT_PUBLIC_GOOGLE_CLIENT_ID.
# O backend também precisa aceitar o mesmo client id em GOOGLE_CLIENT_ID
# ou GOOGLE_ALLOWED_CLIENT_IDS para validar o ID token em /auth/oauth/google.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=
# Opcional: lista CSV de client IDs válidos (produção, preview, local)
GOOGLE_ALLOWED_CLIENT_IDS=
# Opcional para GIS login; exigido por integrações como Calendar/code flow
GOOGLE_CLIENT_SECRET=

# Redirect URIs no Apple:
#   ${NEXTAUTH_URL}/api/auth/callback/apple
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ============================================
# 💳 STRIPE (Billing)
# ============================================
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_PRICE_STARTER=price_xxx
# STRIPE_PRICE_PRO=price_xxx
# STRIPE_PRICE_ENTERPRISE=price_xxx
# BILLING_MOCK_MODE=false

# ============================================
# 🤖 AI / OpenAI
# ============================================
# OPENAI_API_KEY=sk-xxx

# ============================================
# 📱 WAHA (WhatsApp HTTP API)
# ============================================
# Instância WAHA Plus (multi-sessão por workspace)
# Documentação: https://waha.devlike.pro/docs/overview/introduction/
WAHA_API_URL=https://seu-waha.up.railway.app
WAHA_API_KEY=your-waha-api-key
# Aliases legados aceitos pelo runtime
WAHA_BASE_URL=https://seu-waha.up.railway.app
WAHA_API_TOKEN=your-waha-api-key
WAHA_MULTISESSION=true
WAHA_USE_WORKSPACE_SESSION=true
WAHA_SINGLE_SESSION=false
WAHA_NOWEB_STORE_ENABLED=true
WAHA_NOWEB_STORE_FULL_SYNC=true
WAHA_STORE_ENABLED=true
WAHA_STORE_FULL_SYNC=true

# Catch-up/backfill e respostas reativas do Kloel
WAHA_CATCHUP_LOOKBACK_MS=43200000
WAHA_CATCHUP_MAX_CHATS=200
WAHA_CATCHUP_MAX_MESSAGES_PER_CHAT=100
WAHA_CATCHUP_MAX_PAGES_PER_CHAT=10
WAHA_CATCHUP_MAX_PASSES=5
ENABLE_LEGACY_AUTOPILOT_SCANNER=false
AUTOPILOT_BYPASS_REACTIVE_COMPLIANCE=true
AUTOPILOT_BYPASS_REACTIVE_RATELIMITS=true

# ============================================
# 📊 OBSERVABILIDADE
# ============================================
# SENTRY_DSN=https://xxx@sentry.io/xxx
# METRICS_TOKEN=token-para-endpoints-de-metricas

# ============================================
# � STORAGE (S3 / R2 / Local)
# ============================================
# STORAGE_DRIVER=local  # 'local' | 's3' | 'r2'
# CDN_BASE_URL=https://cdn.seu-dominio.com
# 
# Para S3:
# S3_BUCKET=seu-bucket
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=xxx
# AWS_SECRET_ACCESS_KEY=xxx
# S3_PUBLIC_URL=https://seu-bucket.s3.amazonaws.com
#
# Para Cloudflare R2:
# R2_BUCKET=seu-bucket
# R2_ACCOUNT_ID=xxx
# R2_ACCESS_KEY_ID=xxx
# R2_SECRET_ACCESS_KEY=xxx

# ============================================
# 📱 TELEGRAM BOT
# ============================================
# TELEGRAM_BOT_TOKEN=seu-bot-token
# TELEGRAM_WEBHOOK_SECRET=token-secreto-para-validar-webhooks

# ============================================
# 📸 META (Instagram / Messenger)
# ============================================
# META_APP_SECRET=seu-app-secret-para-validar-webhooks
# FACEBOOK_APP_SECRET=mesmo-que-META_APP_SECRET

# ============================================
# �🐳 DOCKER COMPOSE PRODUÇÃO
# ============================================
# Variáveis usadas pelo docker-compose.prod.yml
# POSTGRES_USER=whatsapp_saas
# POSTGRES_PASSWORD=senha-segura-postgres
# POSTGRES_DB=whatsapp_saas
# REDIS_PASSWORD=senha-segura-redis
# DOMAIN=seu-dominio.com
