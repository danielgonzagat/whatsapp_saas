{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2021",
    "strict": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "types": ["node", "jest", "vitest"],
    "outDir": "./dist",
    "rootDir": "./",
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": false
  },
  "include": ["./**/*.ts"],
  "exclude": ["dist", "node_modules", "parser-tests"]
}
