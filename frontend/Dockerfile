# Frontend (Next.js) Dockerfile
# Multi-stage build para produção

FROM node:20-bookworm@sha256:8f693eaa7e0a8e71560c9a82b55fd54c2ae920a2ba5d2cde28bac7d1c01c9ba5 AS deps
WORKDIR /app
COPY package*.json ./
RUN npm ci

FROM node:20-bookworm@sha256:8f693eaa7e0a8e71560c9a82b55fd54c2ae920a2ba5d2cde28bac7d1c01c9ba5 AS builder
WORKDIR /app
ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_GOOGLE_CLIENT_ID
ARG NEXT_PUBLIC_SCREENCAST_WS_URL
ARG NEXT_PUBLIC_DD_SITE
ARG NEXT_PUBLIC_DD_SERVICE
ARG NEXT_PUBLIC_DD_ENV
ARG NEXT_PUBLIC_DD_VERSION
ARG NEXT_PUBLIC_DD_CLIENT_TOKEN
ARG NEXT_PUBLIC_DD_APPLICATION_ID
ARG NEXT_PUBLIC_DD_SESSION_SAMPLE_RATE
ARG NEXT_PUBLIC_DD_SESSION_REPLAY_SAMPLE_RATE
ARG NEXT_PUBLIC_DD_LOGS_SESSION_SAMPLE_RATE
ARG NEXT_PUBLIC_DD_FORWARD_CONSOLE_LOGS
ARG NEXT_PUBLIC_DD_RUM_ENABLED
ARG NEXT_PUBLIC_DD_LOGS_ENABLED
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
ENV NEXT_PUBLIC_GOOGLE_CLIENT_ID=${NEXT_PUBLIC_GOOGLE_CLIENT_ID}
ENV NEXT_PUBLIC_SCREENCAST_WS_URL=${NEXT_PUBLIC_SCREENCAST_WS_URL}
ENV NEXT_PUBLIC_DD_SITE=${NEXT_PUBLIC_DD_SITE}
ENV NEXT_PUBLIC_DD_SERVICE=${NEXT_PUBLIC_DD_SERVICE}
ENV NEXT_PUBLIC_DD_ENV=${NEXT_PUBLIC_DD_ENV}
ENV NEXT_PUBLIC_DD_VERSION=${NEXT_PUBLIC_DD_VERSION}
ENV NEXT_PUBLIC_DD_CLIENT_TOKEN=${NEXT_PUBLIC_DD_CLIENT_TOKEN}
ENV NEXT_PUBLIC_DD_APPLICATION_ID=${NEXT_PUBLIC_DD_APPLICATION_ID}
ENV NEXT_PUBLIC_DD_SESSION_SAMPLE_RATE=${NEXT_PUBLIC_DD_SESSION_SAMPLE_RATE}
ENV NEXT_PUBLIC_DD_SESSION_REPLAY_SAMPLE_RATE=${NEXT_PUBLIC_DD_SESSION_REPLAY_SAMPLE_RATE}
ENV NEXT_PUBLIC_DD_LOGS_SESSION_SAMPLE_RATE=${NEXT_PUBLIC_DD_LOGS_SESSION_SAMPLE_RATE}
ENV NEXT_PUBLIC_DD_FORWARD_CONSOLE_LOGS=${NEXT_PUBLIC_DD_FORWARD_CONSOLE_LOGS}
ENV NEXT_PUBLIC_DD_RUM_ENABLED=${NEXT_PUBLIC_DD_RUM_ENABLED}
ENV NEXT_PUBLIC_DD_LOGS_ENABLED=${NEXT_PUBLIC_DD_LOGS_ENABLED}
COPY --from=deps /app/node_modules ./node_modules
COPY . .
RUN npm run build

FROM node:20-bookworm@sha256:8f693eaa7e0a8e71560c9a82b55fd54c2ae920a2ba5d2cde28bac7d1c01c9ba5 AS runner
WORKDIR /app
ENV NODE_ENV=production

# Instala apenas deps de produção
COPY package*.json ./
RUN npm ci --omit=dev && npm cache clean --force

# Artefatos de build
COPY --from=builder /app/.next ./.next
COPY --from=builder /app/public ./public
COPY --from=builder /app/next.config.ts ./next.config.ts

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD curl -f http://localhost:${PORT:-3000}/ || exit 1

USER node

# Next respeita -p; PORT pode vir do provedor
CMD ["sh", "-c", "npm run start -- -p ${PORT:-3000}"]
