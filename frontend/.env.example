# Backend API
# BACKEND_URL é usado server-side (rotas API do Next.js)
# NEXT_PUBLIC_API_URL é exposto ao navegador (client-side)
BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
# Aliases legados aceitos pelo frontend/proxy
SERVICE_BASE_URL=http://localhost:3001
NEXT_PUBLIC_SERVICE_BASE_URL=http://localhost:3001

# Produção (Vercel + Railway):
# BACKEND_URL=https://whatsappsaas-copy-production.up.railway.app
# NEXT_PUBLIC_API_URL=https://whatsappsaas-copy-production.up.railway.app
# NEXT_PUBLIC_SCREENCAST_WS_URL=wss://worker-production-6fed.up.railway.app/ws/screencast
NEXT_PUBLIC_SCREENCAST_WS_URL=ws://localhost:3004

# Google Sign-In (Google Identity Services)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
# O backend também precisa aceitar esse mesmo client id em GOOGLE_CLIENT_ID
# (ou listá-lo em GOOGLE_ALLOWED_CLIENT_IDS) para /api/auth/google funcionar.

# Observabilidade frontend
# Habilite apenas se quiser carregar o script do Vercel Speed Insights.
# NEXT_PUBLIC_ENABLE_SPEED_INSIGHTS=true

# WhatsApp Connect sem paywall (para testes/demo)
# Quando "true", o botão "Conectar WhatsApp" pula verificação de assinatura/cartão.
# Em "true" + usuário não logado, cria conta anônima automaticamente.
# NEXT_PUBLIC_WHATSAPP_CONNECT_NO_PAYWALL=true

# WAHA-only:
# O frontend usa exclusivamente o proxy /api/whatsapp-api/*.
# Não configure Evolution/WPP/Baileys no frontend.
