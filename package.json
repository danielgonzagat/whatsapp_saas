{
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "prepare": "husky",
    "railway:backend:build": "npm --prefix backend ci --include=dev && npm --prefix backend run prisma:generate && npm --prefix backend run build",
    "railway:backend:start": "npm --prefix backend run start:prod",
    "lint": "npm --prefix backend exec eslint \"{src,apps,libs,test}/**/*.ts\" && npm --prefix frontend run lint",
    "seatbelt:update": "node scripts/ops/run-eslint-seatbelt.mjs",
    "seatbelt:bootstrap": "node scripts/ops/run-eslint-seatbelt.mjs --bootstrap",
    "seatbelt:check": "node scripts/ops/run-eslint-seatbelt.mjs --frozen",
    "quality:graph": "node scripts/ops/check-madge-cycles.mjs",
    "quality:graph:strict": "node scripts/ops/check-madge-cycles.mjs --strict",
    "quality:dead-code": "node scripts/ops/collect-knip-issues.mjs",
    "quality:dead-code:strict": "knip --config knip.json --max-issues 0",
    "quality:static": "npm run format:check && npm run architecture:check && npm run seatbelt:check && npm run ratchet:check",
    "format": "prettier --write .",
    "format:check": "node scripts/ops/check-formatting.mjs",
    "backend:typecheck": "npm --prefix backend run typecheck",
    "frontend:typecheck": "npm --prefix frontend run typecheck",
    "frontend:build:clean": "node scripts/ops/run-clean-frontend-build.mjs",
    "worker:typecheck": "npm --prefix worker run typecheck",
    "backend:test:coverage": "npm --prefix backend run test:cov -- --runInBand",
    "frontend:test:coverage": "npm --prefix frontend run test -- --coverage",
    "worker:test:coverage": "npm --prefix worker run test -- --coverage",
    "test:coverage": "npm run backend:test:coverage && npm run frontend:test:coverage && npm run worker:test:coverage",
    "coverage:normalize": "node scripts/ops/normalize-lcov-paths.mjs",
    "typecheck": "npm run backend:typecheck && npm run frontend:typecheck && npm run worker:typecheck",
    "prisma:validate": "npm --prefix backend run prisma:validate",
    "prisma:generate": "npm --prefix backend run prisma:generate",
    "db:migrate:prod": "npm --prefix backend run prisma:migrate",
    "guard:db-push": "node scripts/ops/guard-prisma-db-push.mjs",
    "architecture:check": "node scripts/ops/check-architecture-guardrails.mjs",
    "test": "npm --prefix backend run test -- --runInBand && npm --prefix frontend test && npm --prefix worker test",
    "build": "npm --prefix backend run build && npm --prefix frontend run build && npm --prefix worker run build",
    "pulse": "node scripts/pulse/run.js",
    "pulse:report": "node scripts/pulse/run.js --report",
    "pulse:json": "node scripts/pulse/run.js --json",
    "pulse:certify": "node scripts/pulse/run.js --certify",
    "pulse:ci": "node scripts/ops/run-pulse-ci.mjs",
    "codacy:sync": "node scripts/ops/sync-codacy-issues.mjs",
    "ratchet:measure": "node scripts/ops/collect-ratchet-metrics.mjs",
    "ratchet:check": "node scripts/ops/check-ratchet.mjs",
    "ratchet:update": "node scripts/ops/check-ratchet.mjs --write-if-improved",
    "ratchet:bootstrap": "node scripts/ops/check-ratchet.mjs --bootstrap",
    "readiness:check": "node scripts/ops/validate-production-readiness.mjs",
    "ops:audit": "npm run readiness:check && npm run pulse:ci",
    "prepush:scoped": "node scripts/ops/run-scoped-pre-push.mjs",
    "sync:install": "/bin/zsh ./scripts/ops/install-auto-sync-launchagent.sh \"$PWD\"",
    "sync:run": "/bin/zsh ./scripts/ops/auto-sync-main.sh \"$PWD\"",
    "sync:status": "/bin/zsh ./scripts/ops/print-auto-sync-status.sh"
  },
  "lint-staged": {
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{js,cjs,mjs,ts,tsx}": [
      "prettier --write"
    ],
    "backend/**/*.{ts,js}": [
      "bash -c 'cd backend && npx eslint --fix \"$@\"' --"
    ],
    "frontend/**/*.{ts,tsx,js,jsx,mjs}": [
      "bash -c 'cd frontend && npx eslint --fix \"$@\"' --"
    ]
  },
  "overrides": {
    "axios": ">=1.8.0",
    "body-parser": ">=1.20.3",
    "cookie": ">=0.7.0",
    "ejs": ">=3.1.10",
    "path-to-regexp": ">=0.2.0",
    "send": ">=0.19.0",
    "serve-static": ">=1.16.2",
    "qs": ">=6.14.2"
  },
  "dependencies": {
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/schedule": "^6.1.1",
    "lucide-react": "^0.577.0",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "eslint-seatbelt": "^0.1.3",
    "husky": "^9.1.7",
    "knip": "^6.4.1",
    "lint-staged": "^16.2.6",
    "madge": "^8.0.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.2"
  }
}
