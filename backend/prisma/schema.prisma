  @@index([status])
  @@map("RAC_AffiliateRequest")
}

model AffiliateLink {
  id                   String           @id @default(uuid())
  affiliateProductId   String
  affiliateProduct     AffiliateProduct @relation(fields: [affiliateProductId], references: [id], onDelete: Cascade)
  affiliateWorkspaceId String
  code                 String           @unique @default(uuid())
  clicks               Int              @default(0)
  sales                Int              @default(0)
  revenue              Float            @default(0)
  commissionEarned     Float            @default(0)
  active               Boolean          @default(true)
  createdAt            DateTime         @default(now())

  @@index([affiliateWorkspaceId])
  @@index([code])
