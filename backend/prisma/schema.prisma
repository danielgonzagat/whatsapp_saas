// ============================================================================
// SP-8 — Destructive Operations Safety Layer (I-ADMIN-D1 .. D6).
//
// Every destructive admin action (suspend/delete account, refund, force
// logout, cache purge, etc.) routes through DestructiveIntent. The intent
// models a two-phase commit: create -> confirm (with challenge + optional
// OTP) -> execute. The table is protected by a PG trigger that blocks any
// DELETE and any UPDATE outside a narrow allowlist of columns (status,
// executedAt, executedByAdminUserId, resultSnapshot, undoTokenHash, undoAt).
// Service-layer guards provide defense-in-depth on top of the trigger.
// ============================================================================
enum DestructiveIntentKind {
  ACCOUNT_SUSPEND
  ACCOUNT_DEACTIVATE
  ACCOUNT_HARD_DELETE
  PRODUCT_ARCHIVE
  PRODUCT_DELETE
  REFUND_MANUAL
  PAYOUT_CANCEL
  MFA_RESET
  FORCE_LOGOUT_GLOBAL
  CACHE_PURGE
}

enum DestructiveIntentStatus {
  PENDING
  CONFIRMED
  EXECUTING
  EXECUTED
  FAILED
  EXPIRED
  UNDONE
}

model DestructiveIntent {
  id                    String                  @id @default(cuid())
  createdByAdminUserId  String                  @map("created_by_admin_user_id")
  kind                  DestructiveIntentKind
  targetType            String                  @map("target_type")
  targetId              String                  @map("target_id")
  reason                String
  challenge             String
  requiresOtp           Boolean                 @default(false) @map("requires_otp")
  reversible            Boolean                 @default(false)
  status                DestructiveIntentStatus @default(PENDING)
  createdAt             DateTime                @default(now()) @map("created_at")
  expiresAt             DateTime                @map("expires_at")
  confirmedAt           DateTime?               @map("confirmed_at")
  executedAt            DateTime?               @map("executed_at")
  executedByAdminUserId String?                 @map("executed_by_admin_user_id")
  failureMessage        String?                 @map("failure_message")
  resultSnapshot        Json?                   @map("result_snapshot")
  undoTokenHash         String?                 @map("undo_token_hash")
  undoExpiresAt         DateTime?               @map("undo_expires_at")
  undoAt                DateTime?               @map("undo_at")
  ip                    String
  userAgent             String                  @map("user_agent")

  @@index([kind, status, createdAt])
  @@index([createdByAdminUserId, createdAt])
  @@index([targetType, targetId])
  @@map("destructive_intents")
}

// ============================================================================
// SP-9 — Marketplace Treasury (I-ADMIN-W1 .. W6).
//
// Kloel operates as a marketplace: money flows through checkout, most
// of it is provisioned to the producer's KloelWallet, and a fraction
// is retained by the marketplace operator. That retained fraction had no contábil
// representation until this epic. MarketplaceTreasury + MarketplaceTreasuryLedger
// give an append-only, per-currency record of the marketplace operator's own
// balance, split into available / pending / reserved (chargeback
// reserve) buckets.
//
// Design notes:
//   * The ledger is application-enforced append-only, mirroring the
//     KloelWalletLedger pattern (schema.prisma:1569). No database
//     trigger blocks UPDATE/DELETE — keeping parity with the existing
//     producer ledger reduces architectural drift. The reconciliation
//     job catches any drift.
//   * All amounts are BigInt cents. Float is never used in this
//     subsystem (I-ADMIN-W4).
//   * (orderId, kind) uniqueness is enforced by a partial unique
//     index added in the migration so replays never double-credit
//     (I-ADMIN-W5).
// ============================================================================
enum MarketplaceTreasuryBucket {
  AVAILABLE
  PENDING
  RESERVED
}

enum MarketplaceTreasuryLedgerKind {
  MARKETPLACE_FEE_CREDIT
  CHARGEBACK_RESERVE
  REFUND_DEBIT
  CHARGEBACK_DEBIT
  PAYOUT_DEBIT
  ADJUSTMENT_CREDIT
  ADJUSTMENT_DEBIT
  RESERVE_RELEASE
}

model MarketplaceTreasury {
  id                      String   @id @default(cuid())
  currency                String   @unique
  availableBalanceInCents BigInt   @default(0) @map("available_balance_in_cents")
  pendingBalanceInCents   BigInt   @default(0) @map("pending_balance_in_cents")
  reservedBalanceInCents  BigInt   @default(0) @map("reserved_balance_in_cents")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  ledger MarketplaceTreasuryLedger[]

  @@map("marketplace_treasuries")
}

model MarketplaceTreasuryLedger {
  id            String                        @id @default(cuid())
  walletId      String                        @map("wallet_id")
  wallet        MarketplaceTreasury           @relation(fields: [walletId], references: [id], onDelete: Cascade)
  currency      String
  direction     String // 'credit' | 'debit'
  bucket        MarketplaceTreasuryBucket
  amountInCents BigInt                        @map("amount_in_cents")
  kind          MarketplaceTreasuryLedgerKind
  orderId       String?                       @map("order_id")
  feeSnapshotId String?                       @map("fee_snapshot_id")
  reason        String
  metadata      Json?
  createdAt     DateTime                      @default(now()) @map("created_at")

  @@index([walletId, createdAt])
  @@index([kind, createdAt])
  @@index([orderId])
  @@map("marketplace_treasury_ledger")
}

model MarketplaceFee {
  id                   String    @id @default(cuid())
  method               String // 'PIX' | 'CREDIT_CARD' | 'BOLETO' | '*'
  feeBps               Int       @map("fee_bps") // basis points: 1000 = 10%
  fixedFeeInCents      Int       @default(0) @map("fixed_fee_in_cents")
  volumeFloorInCents   BigInt    @default(0) @map("volume_floor_in_cents")
  volumeCeilingInCents BigInt?   @map("volume_ceiling_in_cents")
  activeFrom           DateTime  @default(now()) @map("active_from")
  activeTo             DateTime? @map("active_to")
  createdAt            DateTime  @default(now()) @map("created_at")

  @@index([method, activeFrom])
  @@index([activeTo])
  @@map("marketplace_fees")
}

// ============================================================================
// SP-14 — Admin AI Chat (I-ADMIN-C1 .. C5).
//
// A LLM copilot embedded in the admin panel. The operator asks a
// question in natural language; the assistant calls read-only tools
// (scoped by the operator's permission matrix) to answer. Destructive
// tools never execute directly — they create a DestructiveIntent
// (SP-8) that the operator must confirm manually.
//
// v0 ships the persistence layer + append-only message log + tool
// call audit trail. The LLM provider binding and the floating UI
// land here too, but the LLM call itself is STUBBED out until the
// Anthropic SDK key is wired into the admin deploy. Stub mode
// returns a canned "copilot not yet configured" response so the UI
// can be demoed honestly.
// ============================================================================
enum AdminChatRole {
  USER
  ASSISTANT
  TOOL
  SYSTEM
}

model AdminChatSession {
  id          String             @id @default(cuid())
  adminUserId String             @map("admin_user_id")
  title       String?
  createdAt   DateTime           @default(now()) @map("created_at")
  lastUsedAt  DateTime           @default(now()) @map("last_used_at")
  expiresAt   DateTime           @map("expires_at")
  messages    AdminChatMessage[]

  @@index([adminUserId, lastUsedAt])
  @@map("admin_chat_sessions")
}

model AdminChatMessage {
  id         String           @id @default(cuid())
  sessionId  String           @map("session_id")
  session    AdminChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role       AdminChatRole
  content    String           @db.Text
  toolName   String?          @map("tool_name")
  toolArgs   Json?            @map("tool_args")
  toolResult Json?            @map("tool_result")
  createdAt  DateTime         @default(now()) @map("created_at")

  @@index([sessionId, createdAt])
  @@map("admin_chat_messages")
}

// ============================================================================
// SP-STRIPE-2 — Connect Ledger (FASE 2 of stripe migration plan).
//
// Per-Connected-Account dual-balance ledger. Distinct from MarketplaceTreasury
// (which tracks Kloel's own marketplace treasury balance buckets). This ledger
// tracks each seller/affiliate/supplier/coproducer/manager Stripe account's
// pending vs available cents inside KLOEL's view, independently of what
// Stripe says the connected account technically holds.
//
// All payouts to seller/role bank accounts go through Kloel-orchestrated
// stripe.payouts.create() calls — never automatic. The available_balance
// here is what the dashboard shows as "withdrawable", not what Stripe's
// own balance API reports.
//
// Append-only: LedgerEntry rows are never UPDATEd. Corrections are new
// ADJUSTMENT entries. The two balances on ConnectAccountBalance are the
// running materialized views, recomputable from the ledger at any time.
// ============================================================================

enum ConnectAccountType {
  SELLER
  AFFILIATE
  SUPPLIER
  COPRODUCER
  MANAGER
}

enum ConnectLedgerEntryType {
  CREDIT_PENDING
  MATURE
  DEBIT_PAYOUT
  DEBIT_CHARGEBACK
  DEBIT_REFUND
  ADJUSTMENT
}

model ConnectAccountBalance {
  id                       String             @id @default(cuid())
  workspaceId              String             @map("workspace_id")
  stripeAccountId          String             @unique @map("stripe_account_id")
  accountType              ConnectAccountType @map("account_type")
  pendingBalanceCents      BigInt             @default(0) @map("pending_balance_cents")
  availableBalanceCents    BigInt             @default(0) @map("available_balance_cents")
  lifetimeReceivedCents    BigInt             @default(0) @map("lifetime_received_cents")
  lifetimePaidOutCents     BigInt             @default(0) @map("lifetime_paid_out_cents")
  lifetimeChargebacksCents BigInt             @default(0) @map("lifetime_chargebacks_cents")
  createdAt                DateTime           @default(now()) @map("created_at")
  updatedAt                DateTime           @updatedAt @map("updated_at")

  ledger ConnectLedgerEntry[]

  @@index([workspaceId])
  @@index([accountType])
  @@map("connect_account_balances")
}

model ConnectLedgerEntry {
  id                         String                 @id @default(cuid())
  accountBalanceId           String                 @map("account_balance_id")
  accountBalance             ConnectAccountBalance  @relation(fields: [accountBalanceId], references: [id], onDelete: Restrict)
  type                       ConnectLedgerEntryType
  amountCents                BigInt                 @map("amount_cents")
  balanceAfterPendingCents   BigInt                 @map("balance_after_pending_cents")
  balanceAfterAvailableCents BigInt                 @map("balance_after_available_cents")
  referenceType              String                 @map("reference_type")
  referenceId                String                 @map("reference_id")
  scheduledFor               DateTime?              @map("scheduled_for")
  matured                    Boolean                @default(false)
  metadata                   Json?                  @db.JsonB
  createdAt                  DateTime               @default(now()) @map("created_at")

  @@unique([referenceType, referenceId, type])
  @@index([accountBalanceId, createdAt])
  @@index([scheduledFor, matured])
  @@map("connect_ledger_entries")
}

model ConnectMaturationRule {
  id          String             @id @default(cuid())
  productId   String?            @map("product_id")
  accountType ConnectAccountType @map("account_type")
  delayDays   Int                @map("delay_days")
  active      Boolean            @default(true)
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  @@unique([productId, accountType])
  @@index([productId, accountType])
  @@map("connect_maturation_rules")
}

// ============================================================================
// SP-STRIPE-4 — Prepaid Wallet (FASE 4 of stripe migration plan).
//
// Per-workspace prepaid balance for usage-metered services (AI agent
// messages, WhatsApp sends, generic API calls). Independent of Connect:
// the wallet is funded by direct PaymentIntents on Kloel's marketplace-owned
// Stripe account, then debited atomically as services are consumed.
//
// Append-only transactions table mirrors the LedgerEntry pattern so
// every change has an audit row and the running balance is recomputable
// from history at any time.
// ============================================================================

enum PrepaidWalletTxType {
  TOPUP
  USAGE
  REFUND
  ADJUSTMENT
}

model PrepaidWallet {
  id                         String                     @id @default(cuid())
  workspaceId                String                     @unique @map("workspace_id")
  balanceCents               BigInt                     @default(0) @map("balance_cents")
  currency                   String                     @default("BRL")
  autoRechargeEnabled        Boolean                    @default(false) @map("auto_recharge_enabled")
  autoRechargeThresholdCents BigInt?                    @map("auto_recharge_threshold_cents")
  autoRechargeAmountCents    BigInt?                    @map("auto_recharge_amount_cents")
  defaultPaymentMethodId     String?                    @map("default_payment_method_id")
  stripeCustomerId           String?                    @map("stripe_customer_id")
  createdAt                  DateTime                   @default(now()) @map("created_at")
  updatedAt                  DateTime                   @updatedAt @map("updated_at")
  transactions               PrepaidWalletTransaction[]

  @@index([stripeCustomerId])
  @@map("prepaid_wallets")
}

model PrepaidWalletTransaction {
  id                String              @id @default(cuid())
  walletId          String              @map("wallet_id")
  wallet            PrepaidWallet       @relation(fields: [walletId], references: [id], onDelete: Restrict)
  type              PrepaidWalletTxType
  amountCents       BigInt              @map("amount_cents")
  balanceAfterCents BigInt              @map("balance_after_cents")
  referenceType     String              @map("reference_type")
  referenceId       String              @map("reference_id")
  metadata          Json?               @db.JsonB
  createdAt         DateTime            @default(now()) @map("created_at")

  @@unique([referenceType, referenceId, type])
  @@index([walletId, createdAt])
  @@map("prepaid_wallet_transactions")
}

model UsagePrice {
  id                String   @id @default(cuid())
  operation         String   @unique
  pricePerUnitCents BigInt   @map("price_per_unit_cents")
  unit              String
  active            Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([active])
  @@map("usage_prices")
}

// ============================================================================
// SP-STRIPE-5 — Fraud Engine (FASE 5 of stripe migration plan).
//
// Centralized blacklist shared across all sellers in the marketplace. Each row
// is a (type, value) tuple — duplicate inserts are upserted via the unique
// constraint. Blacklist hits short-circuit the FraudEngine evaluation
// before a PaymentIntent is created so suspect transactions never reach
// Stripe.
// ============================================================================

enum FraudBlacklistType {
  CPF
  CNPJ
  EMAIL
  IP
  DEVICE_FINGERPRINT
  CARD_BIN
}

model FraudBlacklist {
  id        String             @id @default(cuid())
  type      FraudBlacklistType
  value     String
  reason    String
  addedBy   String?            @map("added_by")
  expiresAt DateTime?          @map("expires_at")
  createdAt DateTime           @default(now()) @map("created_at")

  @@unique([type, value])
  @@index([expiresAt])
  @@map("fraud_blacklist")
}
