  totalVisits    Int    @default(0)
  abandonRate    Float  @default(0)
  cancelRate     Float  @default(0)
  conversionRate Float  @default(0)

  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([productId])
}

model ProductCoupon {
  id            String   @id @default(uuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  code          String
  discountType  String   // PERCENT, FIXED
  discountValue Float
  maxUses       Int?
  usedCount     Int      @default(0)
  expiresAt     DateTime?
  active        Boolean  @default(true)

  createdAt     DateTime @default(now())

  @@unique([productId, code])
}

model ProductReview {
  id            String   @id @default(uuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  rating        Int      // 1-5
  comment       String?
  authorName    String?
  verified      Boolean  @default(false)

  createdAt     DateTime @default(now())

  @@index([productId])
}

model ProductCommission {
  id            String   @id @default(uuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  role          String   // COPRODUCER, MANAGER, AFFILIATE
  percentage    Float
  agentName     String?
  agentEmail    String?

  createdAt     DateTime @default(now())

  @@index([productId])
}

model ProductUrl {
  id            String   @id @default(uuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  description   String
  url           String
  isPrivate     Boolean  @default(false)
  active        Boolean  @default(true)

  // AI Learning
  aiLearning    Boolean  @default(false)
  aiTopics      Json?    // What Kloel should learn from this URL
  aiLearnFreq   String?  // weekly, biweekly, monthly, manual
  aiLearnStatus String?  // pending, learning, learned, error

  // Chat Widget
  chatEnabled   Boolean  @default(false)
  chatConfig    Json?    // position, color, welcome message, delay, discount

