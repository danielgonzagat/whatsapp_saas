model KloelSale {
  id                String   @id @default(uuid())
  workspaceId       String
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leadId            String?
  leadPhone         String?
  productName       String?
  amount            Float
  status            String   @default("pending") // "pending", "paid", "cancelled", "refunded", "overdue"
