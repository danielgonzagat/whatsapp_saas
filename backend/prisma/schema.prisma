// ============================================
// PRODUCT CATALOG
// ============================================
model Product {
  id          String   @id @default(uuid())
  workspaceId String

  name        String
  description String?
  price       Float
  currency    String   @default("BRL")

  // Categorization
  category    String?
  sku         String?  // Stock Keeping Unit
  tags        String[] @default([])
  format      String   @default("PHYSICAL") // PHYSICAL, DIGITAL, HYBRID

  // Media
  imageUrl    String?
  images      Json?    // Array of image URLs

  // Payment Integration
  paymentLink String?  // Asaas, Stripe, etc

  // Status
  active      Boolean  @default(true)
  featured    Boolean  @default(false)
  status      String   @default("DRAFT") // DRAFT, PENDING, APPROVED, REJECTED

  // Stock (optional)
  stockQuantity Int?
  trackStock    Boolean @default(false)

  // URLs
  salesPageUrl     String?
  thankyouUrl      String?
  thankyouBoletoUrl String?
  thankyouPixUrl   String?
  reclameAquiUrl   String?
  supportEmail     String?

  // Shipping (physical products)
  warrantyDays     Int?
  isSample         Boolean @default(false)
  shippingType     String? // VARIABLE, FIXED, FREE, NONE
  shippingValue    Float?
  originCep        String?

  // SEO/Display
  slug        String?

  // Metadata
  metadata    Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  plans       ProductPlan[]
  checkouts   ProductCheckout[]
  coupons     ProductCoupon[]
  reviews     ProductReview[]
  commissions ProductCommission[]
  urls        ProductUrl[]
  aiConfig       ProductAIConfig?
  checkoutPlans  CheckoutProductPlan[]

  @@unique([workspaceId, sku])
  @@index([workspaceId, active])
  @@index([workspaceId, category])
  @@index([workspaceId, status])
}

model KloelLead {
  id           String   @id @default(uuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  phone        String
  name         String?
  email        String?
  status       String   @default("new") // "new", "hot", "warm", "cold", "converted", "lost"
  stage        String   @default("new") // "new", "interested", "negotiation", "objection", "closed"
  score        Int      @default(0)     // Lead score (0-100)
  lastMessage  String?                  // Última mensagem recebida
  lastIntent   String?                  // Última intenção detectada
  totalMessages Int     @default(0)
  metadata     Json?    // Histórico de interações, preferências, etc
  
  // Relações
  conversations KloelConversation[]
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@unique([workspaceId, phone])
  @@index([workspaceId, status])
  @@index([workspaceId, stage])
}

// Histórico de conversa por lead (para KLOEL manter contexto)
model KloelConversation {
  id          String   @id @default(uuid())
  leadId      String
  role        String   // "user" | "assistant"
  content     String
  intent      String?  // Intenção detectada na mensagem
  sentiment   String?  // Sentimento (positive, negative, neutral)
  metadata    Json?
  
  lead        KloelLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  @@index([leadId, createdAt])
}

// ============================================
