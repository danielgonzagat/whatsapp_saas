// Carteira virtual do usuário (para split de pagamentos)
//
// Wave 2 P6-2 / I11 — the canonical representation of money in this model
// is the `*InCents` columns (BigInt, integer cents). The Float columns are
// retained for the 7-day observation window during the cut-over (P6-3)
// and will be dropped in a follow-up migration. During the window the
// service layer DUAL-WRITES both columns on every mutation and a
// reconciliation job verifies drift. Read from the Float columns is
// DEPRECATED — use `*InCents / 100` at the DTO boundary.
model KloelWallet {
  id                      String    @id @default(uuid())
  workspaceId             String    @unique
  workspace               Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  availableBalance        Float     @default(0) // DEPRECATED — drop in P6-3
  pendingBalance          Float     @default(0) // DEPRECATED — drop in P6-3
  blockedBalance          Float     @default(0) // DEPRECATED — drop in P6-3
  availableBalanceInCents BigInt    @default(0)
  pendingBalanceInCents   BigInt    @default(0)
  blockedBalanceInCents   BigInt    @default(0)

  transactions  KloelWalletTransaction[]
  ledgerEntries KloelWalletLedger[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("RAC_KloelWallet")
}

model KloelWalletTransaction {
  id            String  @id @default(uuid())
  walletId      String
  type          String
  amount        Float // DEPRECATED — drop in P6-3; use amountInCents
  amountInCents BigInt  @default(0)
  description   String
  status        String  @default("pending")
  reference     String?
  metadata      Json?

  wallet KloelWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([walletId, createdAt])
  @@map("RAC_KloelWalletTransaction")
}

// Wave 2 P6-4 / I12 — KloelWalletLedger.
//
// Append-only audit log of every change to a KloelWallet bucket. Each
// row records the direction (credit/debit), the bucket affected
// (available, pending, blocked), the integer-cent amount, the reason,
// and a reference back to the originating KloelWalletTransaction (when
// applicable). The reconciliation job sums the ledger and asserts the
// derived balance matches the materialised wallet columns; drift raises
// a structured ops alert.
//
// CRITICAL invariants enforced by application code (not at the DB level
// — these would require triggers we deliberately keep out of scope):
//
//   * Ledger entries are NEVER updated. The model has no `updatedAt`.
//   * Ledger entries are NEVER deleted except via wallet cascade.
//   * Every wallet balance mutation has a corresponding ledger append
//     INSIDE the same Prisma $transaction. WalletLedgerService exposes
//     a tx-scoped append() that callers must use.
model KloelWalletLedger {
  id            String      @id @default(uuid())
  workspaceId   String
  walletId      String
  wallet        KloelWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  // Reference to the originating KloelWalletTransaction (nullable for
  // adjustments / corrections that are not tied to a transaction row).
  transactionId String?
  direction     String // 'credit' | 'debit'
  bucket        String // 'available' | 'pending' | 'blocked'
  amountInCents BigInt
  reason        String // 'sale_credit' | 'confirm_payment_credit' | 'confirm_payment_debit' | 'withdrawal_debit' | 'reconcile_settle_credit' | 'reconcile_settle_debit'
  metadata      Json?
  createdAt     DateTime    @default(now())

  @@index([workspaceId, walletId, createdAt])
  @@index([workspaceId, transactionId])
  @@map("RAC_KloelWalletLedger")
}

// Documentos/Catálogos enviáveis via WhatsApp
model Document {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String // Nome amigável do documento (ex: "Catálogo Verão 2025")
  fileName    String // Nome do arquivo original
  filePath    String // Caminho relativo no storage (uploads/)
  mimeType    String // Ex: application/pdf, image/jpeg
  fileSize    Int // Tamanho em bytes
  description String? // Descrição opcional
  category    String? // Categoria (catalogo, contrato, proposta, etc)
  isActive    Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, isActive])
  @@index([workspaceId, category])
  @@map("RAC_Document")
}

// =========================================
// FOLLOW-UP SCHEDULING
// =========================================
model FollowUp {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contactId   String
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  scheduledFor DateTime
  message      String? // Mensagem customizada (opcional)

  status String    @default("pending") // pending, sent, cancelled
  sentAt DateTime?

  // Metadata
  reason String? // Motivo do follow-up (ex: "sem resposta 24h", "carrinho abandonado")
  flowId String? // Flow a disparar (opcional)
  flow   Flow?   @relation(fields: [flowId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, status, scheduledFor])
  @@index([workspaceId, contactId])
  @@map("RAC_FollowUp")
}

// ============================================
// MARKETING ARTIFICIAL — Product Plans
// ============================================

model ProductPlan {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  name         String
  price        Float
  currency     String @default("BRL")
  billingType  String @default("ONE_TIME") // ONE_TIME, RECURRING, FREE
  itemsPerPlan Int    @default(1)

  // Payment config
  maxInstallments   Int?
  maxNoInterest     Int?
  discountByPayment Boolean @default(false)
  recurringInterval String? // WEEKLY, BIWEEKLY, MONTHLY, QUARTERLY, SEMIANNUAL, ANNUAL
  trialEnabled      Boolean @default(false)
  trialDays         Int?
  trialPrice        Float?

  // Display
  visibleToAffiliates Boolean @default(true)
  active              Boolean @default(true)
  salesCount          Int     @default(0)

  // Shipping & Delivery
  packagingConfig Json?
  shippingConfig  Json?
  deliveryFiles   Json?

  // Order Bump
  orderBumpPlanId String?
  orderBumpText   String?

  // Terms
  termsUrl String?

  // Checkout customization
  checkoutImages Json?

  // Thank you URLs (plan-level override)
  thankyouUrl       String?
  thankyouBoletoUrl String?
  thankyouPixUrl    String?

  // AI Configuration (the secret weapon — Marketing Artificial)
  aiConfig Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, active])
  @@map("RAC_ProductPlan")
}

model ProductCheckout {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  name   String
  code   String @unique @default(uuid())
  config Json   @default("{}") // All 14 configuration sections as JSON

  // Metrics
  uniqueVisits   Int   @default(0)
  totalVisits    Int   @default(0)
  abandonRate    Float @default(0)
  cancelRate     Float @default(0)
  conversionRate Float @default(0)

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@map("RAC_ProductCheckout")
}

model ProductCoupon {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  code          String
  discountType  String // PERCENT, FIXED
  discountValue Float
  maxUses       Int?
  usedCount     Int       @default(0)
  expiresAt     DateTime?
  active        Boolean   @default(true)

  createdAt DateTime @default(now())

  @@unique([productId, code])
  @@map("RAC_ProductCoupon")
}

model ProductReview {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  rating     Int // 1-5
  comment    String?
  authorName String?
  verified   Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([productId])
  @@map("RAC_ProductReview")
}

model ProductCommission {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  role       String // COPRODUCER, MANAGER, AFFILIATE
  percentage Float
  agentName  String?
  agentEmail String?

  createdAt DateTime @default(now())

  @@index([productId])
  @@map("RAC_ProductCommission")
}

model ProductUrl {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  description String
  url         String
  isPrivate   Boolean @default(false)
  active      Boolean @default(true)

  // AI Learning
  aiLearning    Boolean @default(false)
  aiTopics      Json? // What Kloel should learn from this URL
  aiLearnFreq   String? // weekly, biweekly, monthly, manual
  aiLearnStatus String? // pending, learning, learned, error

  // Chat Widget
  chatEnabled Boolean @default(false)
  chatConfig  Json? // position, color, welcome message, delay, discount

  // Metrics
  salesFromUrl Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, active])
  @@map("RAC_ProductUrl")
}

model ProductCampaign {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  code       String   @default(cuid())
  name       String
  pixelId    String?
  salesCount Int      @default(0)
  paidCount  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([productId])
  @@map("RAC_ProductCampaign")
}

model ProductAIConfig {
  id        String  @id @default(uuid())
  productId String  @unique
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Customer Ideal Profile
  customerProfile Json?

  // Plan Positioning
  positioning Json?

  // Objections & Responses
  objections Json?

  // Sales Arguments
  salesArguments Json?

  // Upsell/Downsell
  upsellConfig   Json?
  downsellConfig Json?

  // AI Behavior
  tone             String? @default("CONSULTIVE")
  persistenceLevel Int?    @default(3)
  messageLimit     Int?    @default(10)
  followUpConfig   Json?

  // Technical Info
  technicalInfo Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("RAC_ProductAIConfig")
}

// ============================================
// MEMBER AREAS (Courses, Communities, etc.)
// ============================================

model MemberArea {
  id            String             @id @default(uuid())
  workspaceId   String
  productId     String?
  name          String
  slug          String
  description   String?
  type          String             @default("COURSE")
  template      String             @default("academy")
  logoUrl       String?
  coverUrl      String?
  primaryColor  String?            @default("#E85D30")
  customDomain  String?
  certificates  Boolean            @default(true)
  quizzes       Boolean            @default(true)
  community     Boolean            @default(true)
  gamification  Boolean            @default(true)
  progressTrack Boolean            @default(true)
  downloads     Boolean            @default(true)
  comments      Boolean            @default(true)
  totalStudents Int                @default(0)
  totalModules  Int                @default(0)
  totalLessons  Int                @default(0)
  avgCompletion Float              @default(0)
  avgRating     Float              @default(0)
  aiGenerated   Boolean            @default(false)
  active        Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  modules       MemberModule[]
  enrollments   MemberEnrollment[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, active])
  @@map("RAC_MemberArea")
}

model MemberEnrollment {
  id           String     @id @default(uuid())
  workspaceId  String
  memberAreaId String
  memberArea   MemberArea @relation(fields: [memberAreaId], references: [id], onDelete: Cascade)
  studentName  String
  studentEmail String
  studentPhone String?
  status       String     @default("active")
  enrolledAt   DateTime   @default(now())
  progress     Float      @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([workspaceId])
  @@index([memberAreaId])
  @@index([studentEmail])
  @@map("RAC_MemberEnrollment")
}

model MemberModule {
  id           String         @id @default(uuid())
  memberAreaId String
  memberArea   MemberArea     @relation(fields: [memberAreaId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  position     Int            @default(0)
  releaseType  String         @default("IMMEDIATE")
  releaseDate  DateTime?
  releaseDays  Int?
  active       Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  lessons      MemberLesson[]

  @@index([memberAreaId, position])
  @@map("RAC_MemberModule")
}

model MemberLesson {
  id            String       @id @default(uuid())
  moduleId      String
  module        MemberModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  type          String       @default("VIDEO")
  position      Int          @default(0)
  videoUrl      String?
  textContent   String?      @db.Text
  downloadUrl   String?
  quizData      Json?
  durationMin   Int?
  transcription String?      @db.Text
  aiSummary     String?
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([moduleId, position])
  @@map("RAC_MemberLesson")
}

// ============================================
// AFFILIATE SYSTEM
// ============================================

model AffiliateProduct {
  id              String             @id @default(uuid())
  productId       String             @unique
  listed          Boolean            @default(true)
  category        String?
  tags            String[]           @default([])
  commissionPct   Float              @default(30)
  commissionType  String             @default("PERCENTAGE")
  commissionFixed Float?
  cookieDays      Int                @default(30)
  approvalMode    String             @default("AUTO")
  totalAffiliates Int                @default(0)
  totalSales      Int                @default(0)
  totalRevenue    Float              @default(0)
  temperature     Int                @default(50)
  thumbnailUrl    String?
  promoMaterials  Json?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  requests        AffiliateRequest[]
  links           AffiliateLink[]

  @@index([listed, category])
  @@index([temperature])
  @@map("RAC_AffiliateProduct")
}

model AffiliateRequest {
  id                   String           @id @default(uuid())
  affiliateProductId   String
