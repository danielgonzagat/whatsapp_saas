  paymentLink       String?
  externalPaymentId String?  @unique // ID do pagamento no gateway (Asaas, Stripe, etc)
  externalId        String?  // Legacy
  paidAt            DateTime?
  metadata          Json?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([workspaceId, status])
