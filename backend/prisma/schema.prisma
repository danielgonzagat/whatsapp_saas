  REFUNDED
  CHARGEBACK
  EXPIRED
}

// PhysicalProduct REMOVED — unified into Product model
// Checkout plans now reference Product directly

model CheckoutProductPlan {
  id                    String               @id @default(cuid())
  productId             String
  product               Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  kind                  CheckoutResourceKind @default(PLAN)
  legacyCheckoutEnabled Boolean              @default(true)
  name                  String
  slug                  String               @unique
  referenceCode         String               @unique @default(cuid())
  priceInCents          Int
  compareAtPrice        Int?
  currency              String               @default("BRL")
  maxInstallments       Int                  @default(12)
  installmentsFee       Boolean              @default(false)
  quantity              Int                  @default(1)
  freeShipping          Boolean              @default(false)
  shippingPrice         Int?
  isActive              Boolean              @default(true)
  checkoutConfig        CheckoutConfig?
  orders                CheckoutOrder[]
  socialLeads           CheckoutSocialLead[]
  orderBumps            OrderBump[]
  upsells               Upsell[]
  checkoutLinks         CheckoutPlanLink[]   @relation("CheckoutLinksByCheckout")
  planLinks             CheckoutPlanLink[]   @relation("CheckoutLinksByPlan")
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([productId])
  @@index([productId, kind])
  @@index([slug])
  @@index([referenceCode])
  @@map("RAC_CheckoutProductPlan")
}

model CheckoutPlanLink {
  id            String              @id @default(cuid())
  checkoutId    String
  checkout      CheckoutProductPlan @relation("CheckoutLinksByCheckout", fields: [checkoutId], references: [id], onDelete: Cascade)
  planId        String
  plan          CheckoutProductPlan @relation("CheckoutLinksByPlan", fields: [planId], references: [id], onDelete: Cascade)
  slug          String?             @unique
  referenceCode String              @unique @default(cuid())
  isPrimary     Boolean             @default(false)
  isActive      Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@unique([checkoutId, planId])
  @@index([checkoutId])
  @@index([planId])
  @@index([referenceCode])
  @@map("RAC_CheckoutPlanLink")
}

model CheckoutConfig {
  id                                     String              @id @default(cuid())
  planId                                 String              @unique
  plan                                   CheckoutProductPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  theme                                  CheckoutTheme       @default(BLANC)
  accentColor                            String?
  accentColor2                           String?
  backgroundColor                        String?
  cardColor                              String?
  textColor                              String?
  mutedTextColor                         String?
  fontBody                               String?
  fontDisplay                            String?
  brandName                              String
  brandLogo                              String?
  headerMessage                          String?
  headerSubMessage                       String?
  productImage                           String?
  productDisplayName                     String?
  btnStep1Text                           String              @default("Ir para Entrega")
  btnStep2Text                           String              @default("Ir para Pagamento")
  btnFinalizeText                        String              @default("Finalizar compra")
