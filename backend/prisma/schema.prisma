// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 🧠 KLOEL - IA Comercial Autônoma
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model KloelMessage {
  id          String   @id @default(uuid())
  workspaceId String
  role        String   // "user" | "assistant" | "system"
  content     String
  metadata    Json?    // Dados extras (intenção, sentimento, etc)
  
  createdAt   DateTime @default(now())
  
  @@index([workspaceId, createdAt])
}

model KloelMemory {
  id          String   @id @default(uuid())
  workspaceId String
  key         String   // Chave única para busca
  value       Json     // Valor armazenado (pode ser qualquer estrutura)
  category    String   @default("general") // "business", "system", "preferences", "catalog"
  type        String?  // "product", "company_info", "persona", "objection", "script", "pdf_analysis"
