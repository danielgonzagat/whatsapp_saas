model MemberLesson {
  id            String   @id @default(uuid())
  moduleId      String
  module        MemberModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  type          String   @default("VIDEO")
  position      Int      @default(0)
  videoUrl      String?
  textContent   String?  @db.Text
  downloadUrl   String?
  quizData      Json?
  durationMin   Int?
  transcription String?  @db.Text
  aiSummary     String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([moduleId, position])
}

// ============================================
// AFFILIATE SYSTEM
// ============================================

model AffiliateProduct {
  id            String   @id @default(uuid())
  productId     String   @unique
  listed        Boolean  @default(true)
  category      String?
  tags          String[] @default([])
  commissionPct Float    @default(30)
  commissionType String  @default("PERCENTAGE")
  commissionFixed Float?
  cookieDays    Int      @default(30)
  approvalMode  String   @default("AUTO")
  totalAffiliates Int    @default(0)
  totalSales      Int    @default(0)
  totalRevenue    Float  @default(0)
  temperature     Int    @default(50)
  thumbnailUrl  String?
  promoMaterials Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  requests      AffiliateRequest[]
  links         AffiliateLink[]
  @@index([listed, category])
  @@index([temperature])
}

model AffiliateRequest {
  id            String   @id @default(uuid())
  affiliateProductId String
  affiliateProduct   AffiliateProduct @relation(fields: [affiliateProductId], references: [id], onDelete: Cascade)
  affiliateWorkspaceId String
  affiliateName        String?
  affiliateEmail       String?
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@unique([affiliateProductId, affiliateWorkspaceId])
  @@index([status])
}

model AffiliateLink {
  id            String   @id @default(uuid())
  affiliateProductId String
  affiliateProduct   AffiliateProduct @relation(fields: [affiliateProductId], references: [id], onDelete: Cascade)
  affiliateWorkspaceId String
  code          String   @unique @default(uuid())
  clicks        Int      @default(0)
  sales         Int      @default(0)
  revenue       Float    @default(0)
  commissionEarned Float @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  @@index([affiliateWorkspaceId])
  @@index([code])
}

// ============================================
// KLOEL SITE BUILDER
// ============================================
model KloelSite {
  id          String   @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String   @default("Site sem titulo")
  slug        String?  @unique
  htmlContent String   @db.Text
  published   Boolean  @default(false)
  productId   String?
  visits      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([workspaceId])
  @@index([slug])
}

// ============================================
// KLOEL CANVAS — Design Editor
// ============================================
model KloelDesign {
  id           String   @id @default(uuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name         String   @default("Design sem titulo")
  format       String   @default("post-ig")
  width        Int      @default(1080)
  height       Int      @default(1080)
  productId    String?
  elements     Json     @default("[]")
  background   String   @default("#0A0A0C")
  thumbnailUrl String?
  status       String   @default("DRAFT")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@index([workspaceId])
  @@index([workspaceId, productId])
}

// ============================================
// CUSTOMER SUBSCRIPTIONS (assinaturas de clientes)
// ============================================
model CustomerSubscription {
  id              String   @id @default(uuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customerName    String
  customerEmail   String
  customerPhone   String?
  productId       String?
  planName        String
  amount          Float
  currency        String   @default("BRL")
  interval        String   @default("MONTHLY")
  status          String   @default("ACTIVE")
  startedAt       DateTime @default(now())
  nextBillingAt   DateTime?
  cancelledAt     DateTime?
  pausedAt        DateTime?
  trialEndsAt     DateTime?
  totalPaid       Float    @default(0)
  paymentsCount   Int      @default(0)
  failedPayments  Int      @default(0)
  externalId      String?
  paymentMethod   String?
  planId          String?
  planChangedAt   DateTime?
  previousPlanId  String?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([workspaceId, status])
  @@index([workspaceId, nextBillingAt])
}

// ============================================
// AD RULES (regras de automacao de anuncios)
// ============================================
model AdRule {
  id          String    @id @default(uuid())
  workspaceId String
  name        String
  condition   String
  action      String
  alertMethod String?
  alertTarget String?
  active      Boolean   @default(true)
  fireCount   Int       @default(0)
  lastFiredAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
}

// ============================================
// PHYSICAL ORDERS (pedidos de produtos fisicos)
// ============================================
model PhysicalOrder {
  id                String   @id @default(uuid())
  workspaceId       String
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customerName      String
  customerEmail     String?
  customerPhone     String?
  productId         String?
  productName       String
  quantity          Int      @default(1)
  amount            Float
  status            String   @default("PROCESSING")
  trackingCode      String?
  trackingUrl       String?
  shippingMethod    String?
  shippingCost      Float?
  addressStreet     String?
  addressCity       String?
  addressState      String?
  addressZip        String?
  addressCountry    String   @default("BR")
  weight            Float?
  shippedAt         DateTime?
  deliveredAt       DateTime?
  estimatedDelivery DateTime?
  paymentMethod     String?
  paymentStatus     String   @default("PAID")
  saleId            String?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
  @@index([trackingCode])
}

model Payment {
  id             String    @id @default(uuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id])
  externalId     String
  provider       String    // "asaas", "stripe", etc.
  status         String    @default("PENDING") // PENDING, CONFIRMED, RECEIVED, REFUNDED, CANCELLED
  amount         Float
  currency       String    @default("BRL")
  method         String?   // "PIX", "CREDIT_CARD", "BOLETO"
  customerEmail  String?
  customerPhone  String?
  metadata       Json?
  paidAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([workspaceId, externalId])
  @@index([workspaceId])
  @@index([externalId])
  @@index([status])
}

model CollaboratorInvite {
  id          String   @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email       String
  role        String
  status      String   @default("PENDING")
  invitedBy   String
  token       String   @unique @default(uuid())
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([workspaceId])
  @@index([email])
  @@index([token])
}

model AffiliatePartner {
  id                 String   @id @default(uuid())
  workspaceId        String
  workspace          Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  partnerName        String
  partnerEmail       String
  partnerPhone       String?
  partnerWorkspaceId String?
  type               String
  commissionRate     Float    @default(30)
  commissionType     String   @default("PERCENTAGE")
  status             String   @default("PENDING")
  totalSales         Int      @default(0)
  totalRevenue       Float    @default(0)
  totalCommission    Float    @default(0)
  temperature        Int      @default(0)
  affiliateLink      String?
  affiliateCode      String?  @unique
  productIds         Json     @default("[]")
  metadata           Json?
  approvedAt         DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  messages           PartnerMessage[]

  @@unique([workspaceId, partnerEmail])
  @@index([workspaceId, status])
  @@index([workspaceId, type])
  @@index([affiliateCode])
}

model PartnerMessage {
  id         String   @id @default(uuid())
  partnerId  String
  senderId   String
  senderType String
  senderName String
  content    String
  readAt     DateTime?
  partner    AffiliatePartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([partnerId, createdAt])
}

model BankAccount {
  id             String   @id @default(uuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  bankName       String
  bankCode       String?
  agency         String?
  account        String?
  accountType    String   @default("CHECKING")
  pixKey         String?
  pixKeyType     String?
  holderName     String?
  holderDocument String?
  isDefault      Boolean  @default(false)
  displayAccount String?
  createdAt      DateTime @default(now())
  @@index([workspaceId])
}

model WalletAnticipation {
  id             String   @id @default(uuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  originalAmount Float
  feePercent     Float    @default(3.0)
  feeAmount      Float
  netAmount      Float
  installments   Int?
  status         String   @default("COMPLETED")
  transactionId  String?
  metadata       Json?
  createdAt      DateTime @default(now())
  @@index([workspaceId, createdAt])
}

// ─── Checkout System ───────────────────────────────────────────────────────────

enum ProductStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum CheckoutTheme {
  NOIR
  BLANC
}

enum TimerType {
  COUNTDOWN
  EXPIRATION
  STOCK
}

enum UpsellChargeType {
  ONE_CLICK
  NEW_PAYMENT
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum PixelType {
  FACEBOOK
  GOOGLE_ADS
  GOOGLE_ANALYTICS
  TIKTOK
  KWAI
  TABOOLA
  CUSTOM
}

enum PaymentMethod {
  CREDIT_CARD
  PIX
  BOLETO
}

enum OrderStatus {
  PENDING
  PROCESSING
  PAID
  SHIPPED
  DELIVERED
  CANCELED
  REFUNDED
  CHARGEBACK
}

enum PaymentStatus {
  PENDING
  PROCESSING
  APPROVED
  DECLINED
  CANCELED
  REFUNDED
  CHARGEBACK
  EXPIRED
}

// PhysicalProduct REMOVED — unified into Product model
// Checkout plans now reference Product directly

model CheckoutProductPlan {
  id              String    @id @default(cuid())
  productId       String
  product         Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name            String
  slug            String    @unique
  referenceCode   String    @unique @default(cuid())
  priceInCents    Int
  compareAtPrice  Int?
  currency        String    @default("BRL")
  maxInstallments Int       @default(12)
  installmentsFee Boolean   @default(false)
  quantity        Int       @default(1)
  freeShipping    Boolean   @default(false)
  shippingPrice   Int?
  isActive        Boolean   @default(true)
  checkoutConfig  CheckoutConfig?
  orders          CheckoutOrder[]
  orderBumps      OrderBump[]
  upsells         Upsell[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  @@index([productId])
  @@index([slug])
  @@index([referenceCode])
}

model CheckoutConfig {
  id                    String        @id @default(cuid())
  planId                String        @unique
  plan                  CheckoutProductPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  theme                 CheckoutTheme @default(BLANC)
  accentColor           String?
  accentColor2          String?
  backgroundColor       String?
  cardColor             String?
  textColor             String?
  mutedTextColor        String?
  fontBody              String?
  fontDisplay           String?
  brandName             String
  brandLogo             String?
  headerMessage         String?
  headerSubMessage      String?
  productImage          String?
  productDisplayName    String?
  btnStep1Text          String        @default("Ir para Entrega")
  btnStep2Text          String        @default("Ir para Pagamento")
  btnFinalizeText       String        @default("Finalizar compra")
  btnFinalizeIcon       String        @default("lock")
  requireCPF            Boolean       @default(true)
  requirePhone          Boolean       @default(true)
  phoneLabel            String        @default("Celular / WhatsApp")
  enableCreditCard      Boolean       @default(true)
  enablePix             Boolean       @default(true)
  enableBoleto          Boolean       @default(false)
  enableCoupon          Boolean       @default(true)
  showCouponPopup       Boolean       @default(true)
  couponPopupDelay      Int           @default(2400)
  couponPopupTitle      String        @default("Presente especial para voce")
  couponPopupDesc       String        @default("Um desconto exclusivo para sua primeira compra.")
  couponPopupBtnText    String        @default("Aplicar desconto")
  couponPopupDismiss    String        @default("Nao, obrigado")
  autoCouponCode        String?
  enableTimer           Boolean       @default(false)
  timerType             TimerType?
  timerMinutes          Int?
  timerMessage          String?
  timerExpiredMessage    String?
  timerPosition         String        @default("top")
  showStockCounter      Boolean       @default(false)
  stockMessage          String?
  fakeStockCount        Int?
  enableTestimonials    Boolean       @default(true)
  testimonials          Json          @default("[]")
  enableGuarantee       Boolean       @default(true)
  guaranteeTitle        String        @default("Garantia de 30 dias")
  guaranteeText         String        @default("Nao gostou? Devolvemos 100% do seu dinheiro.")
  guaranteeDays         Int           @default(30)
  enableTrustBadges     Boolean       @default(true)
  trustBadges           Json          @default("[\"Compra protegida\",\"Dados criptografados\"]")
  footerText            String        @default("Checkout seguro por Kloel")
  showPaymentIcons      Boolean       @default(true)
  metaTitle             String?
  metaDescription       String?
  metaImage             String?
  favicon               String?
  customCSS             String?       @db.Text
  enableExitIntent      Boolean       @default(false)
  exitIntentTitle       String?
  exitIntentDescription String?
  exitIntentCouponCode  String?
  enableFloatingBar     Boolean       @default(false)
  floatingBarMessage    String?

  // Chat Kloel no checkout
  chatEnabled           Boolean       @default(false)
  chatWelcomeMessage    String?       @default("Oi! Tem alguma duvida? Estou aqui pra ajudar")
  chatDelay             Int?          @default(3000)
  chatPosition          String?       @default("bottom-right")
  chatColor             String?
  chatOfferDiscount     Boolean       @default(false)
  chatDiscountCode      String?
  chatSupportPhone      String?

  // Social Proof
  socialProofEnabled    Boolean       @default(false)
  socialProofAlerts     Json?         @default("[]")
  socialProofCustomNames String?      @db.Text

  // Etapas
  enableSteps           Boolean       @default(true)

  // Imagens basicas
  coverImage            String?
  secondaryImage        String?
  sideImage             String?

  pixels                CheckoutPixel[]
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

model OrderBump {
  id              String   @id @default(cuid())
  planId          String
  plan            CheckoutProductPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  title           String
  description     String   @db.Text
  productName     String
  image           String?
  priceInCents    Int
  compareAtPrice  Int?
  highlightColor  String?
  checkboxLabel   String   @default("Sim, eu quero!")
  position        String   @default("before_payment")
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([planId])
}

model Upsell {
  id              String          @id @default(cuid())
  planId          String
  plan            CheckoutProductPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  title           String
  headline        String          @db.Text
  description     String          @db.Text
  productName     String
  image           String?
  priceInCents    Int
  compareAtPrice  Int?
  acceptBtnText   String          @default("Sim, quero essa oferta!")
  declineBtnText  String          @default("Nao, obrigado")
  timerSeconds    Int?
  chargeType      UpsellChargeType @default(ONE_CLICK)
  isActive        Boolean         @default(true)
  sortOrder       Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  @@index([planId])
}

model CheckoutCoupon {
  id              String       @id @default(cuid())
  workspaceId     String
  code            String
  discountType    DiscountType
  discountValue   Int
  minOrderValue   Int?
  maxUses         Int?
  usedCount       Int          @default(0)
  maxUsesPerUser  Int?
  startsAt        DateTime?
  expiresAt       DateTime?
  appliesTo       Json         @default("[]")
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  @@unique([workspaceId, code])
  @@index([workspaceId])
  @@index([code])
}

model CheckoutPixel {
  id                    String      @id @default(cuid())
  checkoutConfigId      String
  checkoutConfig        CheckoutConfig @relation(fields: [checkoutConfigId], references: [id], onDelete: Cascade)
  type                  PixelType
  pixelId               String
  accessToken           String?
  trackPageView         Boolean     @default(true)
  trackInitiateCheckout Boolean     @default(true)
  trackAddPaymentInfo   Boolean     @default(true)
  trackPurchase         Boolean     @default(true)
  isActive              Boolean     @default(true)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  @@index([checkoutConfigId])
}

model CheckoutOrder {
  id                String        @id @default(cuid())
  planId            String
  plan              CheckoutProductPlan @relation(fields: [planId], references: [id])
  workspaceId       String
  orderNumber       String        @unique
  customerName      String
  customerEmail     String
  customerCPF       String?
  customerPhone     String?
  shippingAddress   Json
  shippingMethod    String?
  shippingPrice     Int           @default(0)
  subtotalInCents   Int
  discountInCents   Int           @default(0)
  bumpTotalInCents  Int           @default(0)
  totalInCents      Int
  couponCode        String?
  couponDiscount    Int?
  acceptedBumps     Json          @default("[]")
  paymentMethod     PaymentMethod
  installments      Int           @default(1)
  status            OrderStatus   @default(PENDING)
  affiliateId       String?
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?
  utmContent        String?
  utmTerm           String?
  ipAddress         String?
  userAgent         String?
  payment           CheckoutPayment?
  upsellOrders      UpsellOrder[]
  trackingCode      String?
  trackingUrl       String?
  paidAt            DateTime?
  shippedAt         DateTime?
  deliveredAt       DateTime?
  canceledAt        DateTime?
  refundedAt        DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  @@index([workspaceId])
  @@index([planId])
  @@index([customerEmail])
  @@index([orderNumber])
  @@index([status])
}

model CheckoutPayment {
  id              String        @id @default(cuid())
  orderId         String        @unique
  order           CheckoutOrder @relation(fields: [orderId], references: [id])
  gateway         String
  externalId      String?
  pixQrCode       String?       @db.Text
  pixCopyPaste    String?       @db.Text
  pixExpiresAt    DateTime?
  boletoUrl       String?
  boletoBarcode   String?
  boletoExpiresAt DateTime?
  cardLast4       String?
  cardBrand       String?
  status          PaymentStatus @default(PENDING)
  webhookData     Json?         @db.JsonB
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  @@index([externalId])
}

model UpsellOrder {
  id              String      @id @default(cuid())
  orderId         String
  order           CheckoutOrder @relation(fields: [orderId], references: [id])
  upsellId        String
  productName     String
  priceInCents    Int
  status          OrderStatus @default(PENDING)
  createdAt       DateTime    @default(now())
  @@index([orderId])
}

model KycDocument {
  id             String   @id @default(uuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  agentId        String
  agent          Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  type           String   // DOCUMENT_FRONT, DOCUMENT_BACK, PROOF_OF_ADDRESS, COMPANY_DOCUMENT
  fileUrl        String
  fileName       String
  fileSize       Int
  mimeType       String
  status         String   @default("pending")
  rejectedReason String?
  reviewedAt     DateTime?
  createdAt      DateTime @default(now())
  @@index([workspaceId])
  @@index([agentId])
}

model FiscalData {
  id                   String   @id @default(uuid())
  workspaceId          String   @unique
  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  type                 String   // PF, PJ
  cpf                  String?
  fullName             String?
  cnpj                 String?
  razaoSocial          String?
  nomeFantasia         String?
  inscricaoEstadual    String?
  inscricaoMunicipal   String?
  responsavelCpf       String?
  responsavelNome      String?
  cep                  String?
  street               String?
  number               String?
  complement           String?
  neighborhood         String?
  city                 String?
  state                String?
  status               String   @default("pending")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  @@index([workspaceId])
}
