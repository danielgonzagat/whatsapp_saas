// ============================================
// PRODUCT CATALOG
// ============================================
model Product {
  id          String   @id @default(uuid())
  workspaceId String

  name        String
  description String?
  price       Float
  currency    String   @default("BRL")

  // Categorization
  category    String?
  sku         String?  // Stock Keeping Unit
  tags        String[] @default([])
  format      String   @default("PHYSICAL") // PHYSICAL, DIGITAL, HYBRID

  // Media
  imageUrl    String?
  images      Json?    // Array of image URLs

  // Payment Integration
  paymentLink String?  // Asaas, Stripe, etc

  // Status
  active      Boolean  @default(true)
  featured    Boolean  @default(false)
  status      String   @default("DRAFT") // DRAFT, PENDING, APPROVED, REJECTED

  // Stock (optional)
  stockQuantity Int?
  trackStock    Boolean @default(false)

  // URLs
  salesPageUrl     String?
  thankyouUrl      String?
  thankyouBoletoUrl String?
  thankyouPixUrl   String?
  reclameAquiUrl   String?
  supportEmail     String?

  // Shipping (physical products)
  warrantyDays     Int?
  isSample         Boolean @default(false)
  shippingType     String? // VARIABLE, FIXED, FREE, NONE
  shippingValue    Float?
  originCep        String?

  // SEO/Display
  slug        String?

  // Metadata
  metadata    Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  plans       ProductPlan[]
  checkouts   ProductCheckout[]
  coupons     ProductCoupon[]
  reviews     ProductReview[]
  commissions ProductCommission[]
  urls        ProductUrl[]
  aiConfig    ProductAIConfig?

  @@unique([workspaceId, sku])
  @@index([workspaceId, active])
  @@index([workspaceId, category])
  @@index([workspaceId, status])
}

model KloelLead {
  id           String   @id @default(uuid())
  workspaceId  String
  phone        String
  name         String?
  email        String?
  status       String   @default("new") // "new", "hot", "warm", "cold", "converted", "lost"
  stage        String   @default("new") // "new", "interested", "negotiation", "objection", "closed"
  score        Int      @default(0)     // Lead score (0-100)
  lastMessage  String?                  // Última mensagem recebida
  lastIntent   String?                  // Última intenção detectada
  totalMessages Int     @default(0)
  metadata     Json?    // Histórico de interações, preferências, etc
  
  // Relações
  conversations KloelConversation[]
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@unique([workspaceId, phone])
  @@index([workspaceId, status])
  @@index([workspaceId, stage])
}

// Histórico de conversa por lead (para KLOEL manter contexto)
model KloelConversation {
  id          String   @id @default(uuid())
  leadId      String
  role        String   // "user" | "assistant"
  content     String
  intent      String?  // Intenção detectada na mensagem
  sentiment   String?  // Sentimento (positive, negative, neutral)
  metadata    Json?
  
  lead        KloelLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  @@index([leadId, createdAt])
}

model KloelSale {
  id                String   @id @default(uuid())
  workspaceId       String
  leadId            String?
  leadPhone         String?
  productName       String?
  amount            Float
  status            String   @default("pending") // "pending", "paid", "cancelled", "refunded", "overdue"
  paymentMethod     String?  // "PIX", "CREDIT_CARD", "BOLETO"
  paymentLink       String?
  externalPaymentId String?  @unique // ID do pagamento no gateway (Asaas, Stripe, etc)
  externalId        String?  // Legacy
  paidAt            DateTime?
  metadata          Json?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([workspaceId, status])
}

// Carteira virtual do usuário (para split de pagamentos)
model KloelWallet {
  id               String   @id @default(uuid())
  workspaceId      String   @unique
  availableBalance Float    @default(0)
  pendingBalance   Float    @default(0)
  blockedBalance   Float    @default(0)
  
  transactions     KloelWalletTransaction[]
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model KloelWalletTransaction {
  id          String   @id @default(uuid())
  walletId    String
  type        String
  amount      Float
  description String
  status      String   @default("pending")
  reference   String?
  metadata    Json?
  
  wallet      KloelWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  @@index([walletId, createdAt])
}

// Documentos/Catálogos enviáveis via WhatsApp
model Document {
  id           String   @id @default(uuid())
  workspaceId  String
  name         String   // Nome amigável do documento (ex: "Catálogo Verão 2025")
  fileName     String   // Nome do arquivo original
  filePath     String   // Caminho relativo no storage (uploads/)
  mimeType     String   // Ex: application/pdf, image/jpeg
  fileSize     Int      // Tamanho em bytes
  description  String?  // Descrição opcional
  category     String?  // Categoria (catalogo, contrato, proposta, etc)
  isActive     Boolean  @default(true)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@index([workspaceId, isActive])
  @@index([workspaceId, category])
}

// =========================================
// FOLLOW-UP SCHEDULING
// =========================================
model FollowUp {
  id           String   @id @default(uuid())
  workspaceId  String
  contactId    String
  
  scheduledFor DateTime
  message      String?  // Mensagem customizada (opcional)
  
  status       String   @default("pending") // pending, sent, cancelled
  sentAt       DateTime?
  
  // Metadata
  reason       String?  // Motivo do follow-up (ex: "sem resposta 24h", "carrinho abandonado")
  flowId       String?  // Flow a disparar (opcional)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@index([workspaceId, status, scheduledFor])
  @@index([workspaceId, contactId])
}

// ============================================
// MARKETING ARTIFICIAL — Product Plans
// ============================================

model ProductPlan {
  id            String   @id @default(uuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  name          String
  price         Float
  currency      String   @default("BRL")
  billingType   String   @default("ONE_TIME") // ONE_TIME, RECURRING, FREE
  itemsPerPlan  Int      @default(1)

  // Payment config
  maxInstallments    Int?
  maxNoInterest      Int?
  discountByPayment  Boolean @default(false)
  recurringInterval  String? // WEEKLY, BIWEEKLY, MONTHLY, QUARTERLY, SEMIANNUAL, ANNUAL
  trialEnabled       Boolean @default(false)
  trialDays          Int?
  trialPrice         Float?

  // Display
  visibleToAffiliates Boolean @default(true)
  active              Boolean @default(true)
  salesCount          Int     @default(0)

  // Shipping & Delivery
  packagingConfig  Json?
  shippingConfig   Json?
  deliveryFiles    Json?

  // Order Bump
  orderBumpPlanId  String?
  orderBumpText    String?

  // Terms
  termsUrl         String?

  // Checkout customization
  checkoutImages   Json?

  // Thank you URLs (plan-level override)
  thankyouUrl      String?
  thankyouBoletoUrl String?
  thankyouPixUrl   String?

  // AI Configuration (the secret weapon — Marketing Artificial)
  aiConfig         Json?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([productId, active])
}

model ProductCheckout {
  id            String   @id @default(uuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  name          String
  code          String   @unique @default(uuid())
  config        Json     @default("{}") // All 14 configuration sections as JSON

  // Metrics
  uniqueVisits   Int    @default(0)
  totalVisits    Int    @default(0)
  abandonRate    Float  @default(0)
  cancelRate     Float  @default(0)
  conversionRate Float  @default(0)

  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([productId])
}

model ProductCoupon {
  id            String   @id @default(uuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  code          String
  discountType  String   // PERCENT, FIXED
  discountValue Float
  maxUses       Int?
  usedCount     Int      @default(0)
  expiresAt     DateTime?
  active        Boolean  @default(true)

  createdAt     DateTime @default(now())

  @@unique([productId, code])
}

model ProductReview {
  id            String   @id @default(uuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  rating        Int      // 1-5
  comment       String?
  authorName    String?
  verified      Boolean  @default(false)

  createdAt     DateTime @default(now())

  @@index([productId])
}

model ProductCommission {
  id            String   @id @default(uuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  role          String   // COPRODUCER, MANAGER, AFFILIATE
  percentage    Float
  agentName     String?
  agentEmail    String?

  createdAt     DateTime @default(now())

  @@index([productId])
}

model ProductUrl {
  id            String   @id @default(uuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  description   String
  url           String
  isPrivate     Boolean  @default(false)
  active        Boolean  @default(true)

  // AI Learning
  aiLearning    Boolean  @default(false)
  aiTopics      Json?    // What Kloel should learn from this URL
  aiLearnFreq   String?  // weekly, biweekly, monthly, manual
  aiLearnStatus String?  // pending, learning, learned, error

  // Chat Widget
  chatEnabled   Boolean  @default(false)
  chatConfig    Json?    // position, color, welcome message, delay, discount

  // Metrics
  salesFromUrl  Int      @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([productId, active])
}

model ProductAIConfig {
  id            String   @id @default(uuid())
  productId     String   @unique
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Customer Ideal Profile
  customerProfile Json?

  // Plan Positioning
  positioning     Json?

  // Objections & Responses
  objections      Json?

  // Sales Arguments
  salesArguments  Json?

  // Upsell/Downsell
  upsellConfig    Json?
  downsellConfig  Json?

  // AI Behavior
  tone            String?  @default("CONSULTIVE")
  persistenceLevel Int?    @default(3)
  messageLimit    Int?     @default(10)
  followUpConfig  Json?

  // Technical Info
  technicalInfo   Json?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

