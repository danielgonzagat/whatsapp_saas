{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "types": ["node", "jest"],
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "strict": true,
    "strictFunctionTypes": true,
    "alwaysStrict": true,
    "noImplicitReturns": true,
    "useUnknownInCatchVariables": true
  },
  "exclude": [
    "node_modules",
    "dist",
    "prisma.config.ts",
    "**/*spec.ts",
    "**/*.fixtures.ts",
    "src/pulse/*.spec.ts",
    "src/pulse/**/*.spec.ts",
    "src/pulse/**/*.fixtures.ts"
  ]
}
