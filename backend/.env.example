# ============================================
# KLOEL BACKEND - Variáveis de Ambiente
# ============================================

# ============================================
# Database (PostgreSQL + pgvector)
# ============================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/whatsapp_saas
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=whatsapp_saas

# ============================================
# Redis (Cache + Queues)
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# 🛡️ Rate Limit (Auth) + Abuso
# ============================================
# Os endpoints /auth/* possuem rate limit.
# - Recomendado em produção: configurar REDIS_URL (rate limit distribuído + filas/queues).
# - Se Redis não estiver configurado/indisponível, o backend usa fallback local (por processo)
#   e loga WARN claro (não quebra login, evita abuso óbvio, mas não escala entre instâncias).

# ============================================
# JWT Authentication
# ============================================
# IMPORTANTE: Altere para uma chave segura em produção!
JWT_SECRET=change-me-to-a-secure-random-string
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# Google Sign-In (GIS)
# ============================================
# Fluxo suportado: o frontend recebe a credential (ID token) do Google Identity Services
# e o backend valida esse token em /auth/oauth/google.
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
# Opcional: espelhe o mesmo client id usado no frontend para evitar divergência
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
# Opcional: lista CSV para aceitar client IDs diferentes em produção/preview/local
GOOGLE_ALLOWED_CLIENT_IDS=
# Opcional neste fluxo específico (mantido para Calendar/code flow)
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# WAHA (WhatsApp HTTP API)
# ============================================
WHATSAPP_PROVIDER_DEFAULT=whatsapp-web-agent
WORKER_BROWSER_RUNTIME_URL=http://worker:3003
WHATSAPP_BROWSER_HEADLESS=true
WHATSAPP_BROWSER_PROFILE_DIR=/data/browser-sessions
WHATSAPP_CUA_PROVIDER=openai
WHATSAPP_CUA_MODE=native
WHATSAPP_IDLE_INTERVAL_MS=45000
WHATSAPP_ACTIVE_INTERVAL_MS=4000
WHATSAPP_ACTIVE_TO_IDLE_MS=60000
WHATSAPP_CHECKPOINT_TTL_SECONDS=604800
SCREENCAST_WS_PORT=3004
SCREENCAST_QUALITY=70
SCREENCAST_MAX_WIDTH=1440
SCREENCAST_MAX_HEIGHT=900
SCREENCAST_EVERY_NTH_FRAME=1
NEXT_PUBLIC_SCREENCAST_WS_URL=wss://seu-worker-stream.up.railway.app
WHATSAPP_LIVE_SCREEN_WRITE_INTERVAL_MS=250
WHATSAPP_FRAME_ARCHIVE_INTERVAL_MS=1000

# Instância WAHA Plus
# Use a URL pública do seu serviço WAHA (sem /api no final)
WAHA_API_URL=https://seu-waha.up.railway.app
WAHA_CATCHUP_INCLUDE_ZERO_UNREAD_ACTIVITY=true
WAHA_CATCHUP_FALLBACK_CHATS_PER_PASS=25
WAHA_CATCHUP_FIRST_RUN_LOOKBACK_MS=2592000000
WAHA_CATCHUP_SEND_SEEN_ON_IMPORT=false
WAHA_CATCHUP_MARK_READ_WITHOUT_REPLY=false
WAHA_WATCHDOG_CONNECTED_MAINTENANCE_INTERVAL_SECONDS=300
CIA_BOOTSTRAP_INCLUDE_ZERO_UNREAD_ACTIVITY=true
CIA_ENABLE_PROACTIVE_CYCLE=false
ALLOW_PROACTIVE_OUTREACH=false
# Alias legado aceito pelo runtime
WAHA_BASE_URL=https://seu-waha.up.railway.app

# Chave de API para autenticação
WAHA_API_KEY=your-waha-api-key
# Alias legado aceito pelo runtime
WAHA_API_TOKEN=your-waha-api-key

# Sessões por workspace: obrigatório para multi-tenant
WAHA_MULTISESSION=true
WAHA_USE_WORKSPACE_SESSION=true
WAHA_SINGLE_SESSION=false

# NOWEB store: obrigatório para catch-up/backfill estável em engine NOWEB
WAHA_NOWEB_STORE_ENABLED=true
WAHA_NOWEB_STORE_FULL_SYNC=true
# Compatibilidade com payloads legados do WAHA
WAHA_STORE_ENABLED=true
WAHA_STORE_FULL_SYNC=true

# Webhook global do WAHA -> backend
# Recomendado em produção para garantir inbound, status e catch-up automáticos
WHATSAPP_HOOK_URL=https://seu-backend.up.railway.app/webhooks/whatsapp-api
WHATSAPP_HOOK_EVENTS=session.status,message,message.any,message.ack
# Exemplo de header customizado no WAHA:
# WHATSAPP_HOOK_CUSTOM_HEADERS=X-Api-Key:my-webhook-secret

# Segredo validado pelo backend no webhook (x-api-key/x-webhook-secret)
WHATSAPP_API_WEBHOOK_SECRET=my-webhook-secret
# Permite subir sessão sem webhook apenas em cenários muito específicos de diagnóstico.
WAHA_ALLOW_SESSION_WITHOUT_WEBHOOK=false
# Permite URL interna/privada para webhook somente em ambientes controlados.
WAHA_ALLOW_INTERNAL_WEBHOOK_URL=false

# Health do worker para o backend consolidar readiness
WORKER_HEALTH_URL=http://worker:3003/health
WORKER_METRICS_TOKEN=change-me-worker-metrics-token
WORKER_FORCE_AVAILABLE=

# Controles de compliance do envio autônomo.
# `reactive` sempre responde a quem acabou de falar; `proactive` respeita essas flags.
ENFORCE_OPTIN=false
AUTOPILOT_ENFORCE_24H=false

# ============================================
# Stripe (Pagamentos)
# ============================================
# Obter em: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Price IDs para cada plano
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_ENTERPRISE=price_xxx

# Modo mock (para desenvolvimento sem Stripe real)
BILLING_MOCK_MODE=true

# ============================================
# OpenAI (brain/writer split para Kloel/Autopilot)
# ============================================
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=
INTERNAL_API_KEY=
OPENAI_BRAIN_MODEL=gpt-5.4
OPENAI_BRAIN_FALLBACK_MODEL=gpt-4.1
OPENAI_WRITER_MODEL=gpt-5.4-nano-2026-03-17
OPENAI_WRITER_FALLBACK_MODEL=gpt-4.1
OPENAI_AUDIO_UNDERSTANDING_MODEL=gpt-tempo-real-1.5
OPENAI_AUDIO_UNDERSTANDING_FALLBACK_MODEL=gpt-4o-mini-transcribe
OPENAI_MODEL=gpt-5.4-nano-2026-03-17
OPENAI_FALLBACK_MODEL=gpt-4.1
VOICE_PROVIDER=elevenlabs
VOICE_RESPONSE_AUDIO_REQUIRED=false
CIA_INLINE_BACKLOG_FALLBACK_LIMIT=10
CIA_BOOTSTRAP_AUTO_CONTINUE=true
CIA_BOOTSTRAP_AUTO_CONTINUE_LIMIT=500

# ============================================
# Email (Nodemailer/SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=Kloel <noreply@kloel.com>

# ============================================
# Frontend URL (para redirects)
# ============================================
FRONTEND_URL=http://localhost:3000

# ============================================
# Prisma Migrations (produção)
# ============================================
# Em produção, o backend executa migrations automaticamente no startup
# (Docker CMD e script start:prod).
# Se o schema não estiver pronto, endpoints de autenticação retornam 503
# com mensagem clara (em vez de falhar com erro genérico).
# ============================================
# Sentry (Monitoramento de erros - opcional)
# ============================================
SENTRY_DSN=

# ============================================
# Ambiente
# ============================================
NODE_ENV=development
PORT=3001

# ============================================
# Autopilot Limits
# ============================================
AUTOPILOT_CONTACT_DAILY_LIMIT=5
AUTOPILOT_WORKSPACE_DAILY_LIMIT=1000
AUTOPILOT_SILENCE_HOURS=24
AUTOPILOT_CYCLE_CRON=* * * * *
AUTOPILOT_CONTACT_DEBOUNCE_MS=2000
AUTOPILOT_PENDING_MESSAGE_LIMIT=12
ENABLE_LEGACY_AUTOPILOT_SCANNER=false
AUTOPILOT_BYPASS_REACTIVE_COMPLIANCE=true
AUTOPILOT_BYPASS_REACTIVE_RATELIMITS=true

# Catch-up/backfill WAHA
WAHA_CATCHUP_LOOKBACK_MS=43200000
WAHA_CATCHUP_MAX_CHATS=200
WAHA_CATCHUP_MAX_MESSAGES_PER_CHAT=100
WAHA_CATCHUP_MAX_PAGES_PER_CHAT=10
WAHA_CATCHUP_MAX_PASSES=5

# ============================================
# Rate Limiting
# ============================================
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ============================================
# Guest Chat (chat público sem login)
# ============================================
# Habilitado por padrão. Defina como "false" para desabilitar em produção.
GUEST_CHAT_ENABLED=true

# ============================================
# CORS - Origens extras (CSV)
# ============================================
# Adicione domínios extras separados por vírgula (ex.: Railway, custom domain).
# As origens padrão (kloel.com, vercel, localhost) já estão incluídas.
# CORS_ALLOWED_ORIGINS=https://myapp.up.railway.app,https://custom.domain.com

# Regex patterns para origens dinâmicas (CSV de regex, ex.: Vercel preview deploys).
# O padrão ^https://kloel-frontend-.*\.vercel\.app$ já está incluído por default.
# CORS_ALLOWED_ORIGIN_REGEX=^https://my-other-app-.*\.vercel\.app$

# ============================================
# Health/Readiness
# ============================================
# GET /health          -> liveness simples
# GET /health/system   -> health consolidado (DB, Redis, WAHA, worker, config)
# GET /health/ready    -> alias de readiness
