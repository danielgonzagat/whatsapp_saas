# ═══════════════════════════════════════════════════════════════════
# KLOEL BACKEND — ENVIRONMENT VARIABLES REFERENCE
# Generated from codebase scan. Copy to .env and fill in values.
# ═══════════════════════════════════════════════════════════════════

# ═══ REQUIRED ═══
DATABASE_URL=                       # PostgreSQL connection string (e.g. postgresql://user:pass@host:5432/db)
JWT_SECRET=                         # Min 32 chars. REQUIRED in production; dev falls back to insecure default
NODE_ENV=                           # "production" | "development" | "test"
PORT=                               # HTTP listen port (default: 3001)

# ═══ FRONTEND / CORS ═══
FRONTEND_URL=                       # Public frontend URL (default: http://localhost:3000)
ALLOWED_ORIGINS=                    # Comma-separated list of allowed CORS origins
CORS_ALLOWED_ORIGINS=               # Extra CORS origins (comma-separated)
CORS_ALLOWED_ORIGIN_REGEX=          # Regex pattern for dynamic CORS origins

# ═══ AUTHENTICATION ═══
AUTH_OPTIONAL=                      # "true" to skip auth in dev (BLOCKED in production)
AUTH_REQUIRED=                      # "true" to enforce auth on kloel security guard
GOOGLE_CLIENT_ID=                   # Google OAuth 2.0 client ID
GOOGLE_CLIENT_SECRET=               # Google OAuth 2.0 client secret
JWT_EXPIRES_IN=                     # Access token TTL (default: "30m")

# ═══ EMAIL ═══
EMAIL_FROM=                         # Sender email address (default: noreply@kloel.com)
RESEND_API_KEY=                     # Resend.com API key (preferred email provider)
SENDGRID_API_KEY=                   # SendGrid API key (fallback email provider)
SMTP_HOST=                          # SMTP host (fallback if no Resend/SendGrid)

# ═══ REDIS ═══
REDIS_URL=                          # Full Redis connection URL (preferred)
REDIS_PUBLIC_URL=                   # Public Redis URL (takes precedence over REDIS_URL)
REDIS_FALLBACK_URL=                 # Fallback Redis URL if primary fails
REDIS_HOST=                         # Redis host (alternative to URL)
REDIS_PORT=                         # Redis port (default: 6379)
REDIS_USERNAME=                     # Redis ACL username
REDIS_PASSWORD=                     # Redis password
REDIS_HOSTNAME=                     # Alias for REDIS_HOST
REDISHOST=                          # Railway-style Redis host alias
REDISPORT=                          # Railway-style Redis port alias
REDISUSER=                          # Railway-style Redis username alias
REDISPASSWORD=                      # Railway-style Redis password alias
REDIS_USER=                         # Alias for Redis username
REDIS_PASS=                         # Alias for Redis password

# ═══ AI / LLM ═══
OPENAI_API_KEY=                     # OpenAI API key (GPT, TTS, DALL-E, embeddings)
ANTHROPIC_API_KEY=                  # Anthropic API key (site generation)
OPENAI_TTS_VOICE=nova               # OpenAI TTS voice (alloy, echo, fable, onyx, nova, shimmer)
OPENAI_TTS_SPEED=1.0                # OpenAI TTS speed (0.25 to 4.0)

# ═══ WHATSAPP / WAHA ═══
WAHA_API_URL=                       # WAHA Plus API endpoint (primary)
WAHA_BASE_URL=                      # Alias for WAHA_API_URL
WAHA_URL=                           # Alias for WAHA_API_URL
WAHA_API_KEY=                       # WAHA API key for authentication
WAHA_API_TOKEN=                     # Alias for WAHA_API_KEY
WAHA_SESSION_ID=                    # Fixed WAHA session ID (single-session mode)
WAHA_MULTISESSION=                  # "true" to use per-workspace sessions
WAHA_USE_WORKSPACE_SESSION=         # "true" = multisession, "false" = single session
WAHA_SINGLE_SESSION=                # "true" to force single-session mode
WAHA_SESSION_CONFIG_SYNC_TTL_MS=    # Session config cache TTL in ms
WAHA_CHATS_OVERVIEW_TIMEOUT_MS=     # Timeout for chats overview request
WAHA_HOOK_URL=                      # Explicit webhook URL for WAHA events
WHATSAPP_HOOK_URL=                  # Alias for WAHA_HOOK_URL
WAHA_HOOK_EVENTS=                   # Comma-separated list of WAHA webhook events
WHATSAPP_HOOK_EVENTS=               # Alias for WAHA_HOOK_EVENTS
WHATSAPP_HOOK_HMAC_KEY=             # HMAC key for webhook signature verification
WAHA_WEBHOOK_SECRET=                # Webhook secret for WAHA
WHATSAPP_API_WEBHOOK_SECRET=        # Alias for WAHA_WEBHOOK_SECRET
WHATSAPP_VERIFY_TOKEN=              # Verify token for WhatsApp webhook setup (default: kloel_whatsapp_verify_2024)
WHATSAPP_PROVIDER_DEFAULT=          # Default provider: "whatsapp-web-agent" or "waha"
WHATSAPP_BROWSER_ONLY=              # "true" to disable API provider, browser-only mode
WHATSAPP_ACTION_LOCK_MS=            # Lock TTL for WhatsApp actions in ms (default: 45000)

# ═══ WAHA WATCHDOG ═══
WAHA_WATCHDOG_RECONNECT_LOCK_TTL_SECONDS=  # Reconnect lock TTL (default: 300)
WAHA_WATCHDOG_CONNECTED_MAINTENANCE_INTERVAL_SECONDS=  # Maintenance interval (default: 300)
WAHA_WATCHDOG_RUN_ON_STARTUP=       # "false" to disable watchdog on startup

# ═══ WAHA CATCHUP ═══
WAHA_CATCHUP_SWEEP_LIMIT=           # Max messages per sweep (default: 500)
WAHA_CATCHUP_MAX_CHATS=             # Max chats to process (default: 1000)
WAHA_CATCHUP_MAX_MESSAGES_PER_CHAT= # Max messages per chat (default: 100)
WAHA_CATCHUP_MAX_PASSES=            # Max catchup passes (default: 5)
WAHA_CATCHUP_MAX_PAGES_PER_CHAT=    # Max pages per chat (default: 10)
WAHA_CATCHUP_LOOKBACK_MS=           # Lookback window in ms (default: 12h)
WAHA_CATCHUP_FIRST_RUN_LOOKBACK_MS= # First-run lookback window in ms
WAHA_CATCHUP_MIN_TRIGGER_INTERVAL_SECONDS= # Min interval between triggers (default: 60)
WAHA_CATCHUP_FALLBACK_CHATS_PER_PASS= # Fallback chats per pass (default: 100)
WAHA_CATCHUP_FALLBACK_PAGES_PER_CHAT= # Fallback pages per chat (default: 2)
WAHA_CATCHUP_INCLUDE_ZERO_UNREAD_ACTIVITY= # Include chats with 0 unread (default: true)
WAHA_CATCHUP_MARK_READ_WITHOUT_REPLY= # Mark read without replying (default: true)
WAHA_SELF_IDENTITY_TTL_MS=          # Self-identity cache TTL (default: 60000)
WAHA_LID_MAP_CACHE_TTL_MS=          # LID map cache TTL (default: 300000)

# ═══ BACKEND URL DETECTION ═══
APP_URL=                            # Explicit backend public URL
BACKEND_PUBLIC_URL=                 # Alias for APP_URL
BACKEND_URL=                        # Alias for APP_URL
SERVICE_BASE_URL=                   # Alias for APP_URL
NEXT_PUBLIC_API_URL=                # Next.js-style backend URL
NEXT_PUBLIC_SERVICE_BASE_URL=       # Next.js-style service base URL
RAILWAY_STATIC_URL=                 # Railway static URL (auto-detected)
RAILWAY_PUBLIC_DOMAIN=              # Railway public domain (auto-detected)

# ═══ PAYMENTS — STRIPE ═══
STRIPE_SECRET_KEY=                  # Stripe secret key
STRIPE_WEBHOOK_SECRET=              # Stripe webhook endpoint secret
STRIPE_PRICE_STARTER=               # Stripe Price ID for Starter plan
STRIPE_PRICE_PRO=                   # Stripe Price ID for Pro plan
STRIPE_PRICE_ENTERPRISE=            # Stripe Price ID for Enterprise plan

# ═══ PAYMENTS — OTHER ═══
ASAAS_WEBHOOK_TOKEN=                # Asaas webhook verification token
MERCADOPAGO_PUBLIC_KEY=             # Mercado Pago public key used by the frontend
MERCADOPAGO_ACCESS_TOKEN=           # Mercado Pago platform access token
MERCADOPAGO_CLIENT_ID=              # Mercado Pago OAuth client id
MERCADOPAGO_CLIENT_SECRET=          # Mercado Pago OAuth client secret
MERCADOPAGO_PLATFORM_ID=            # Mercado Pago platform id (if provided by MP)
MERCADOPAGO_INTEGRATOR_ID=          # Mercado Pago integrator id (if provided by MP)
MERCADOPAGO_CORPORATION_ID=         # Mercado Pago corporation id when required
MERCADOPAGO_3DS_VALIDATION=         # "always" | "on_fraud_risk" | "never"
MERCADOPAGO_3DS_LIABILITY_SHIFT=    # "required" | "preferred"
MERCADOPAGO_WEBHOOK_SECRET=         # Mercado Pago webhook secret signature key
KLOEL_MARKETPLACE_FEE_PERCENT=      # Kloel platform fee percentage (default: 9.9)
KLOEL_INSTALLMENT_INTEREST_MONTHLY_PERCENT= # Monthly installment interest retained by Kloel
PAYMENT_WEBHOOK_SECRET=             # Generic payment webhook secret
SHOPIFY_WEBHOOK_SECRET=             # Shopify webhook secret
WC_WEBHOOK_SECRET=                  # WooCommerce webhook secret
PAGHIPER_WEBHOOK_TOKEN=             # PagHiper webhook token

# ═══ PAYMENTS — META / SOCIAL ═══
META_APP_SECRET=                    # Meta (Facebook) app secret for webhook verification
FACEBOOK_APP_SECRET=                # Alias for META_APP_SECRET

# ═══ BILLING ═══
BILLING_MOCK_MODE=                  # "true" to mock billing (dev only)
TRIAL_CREDITS_USD=                  # Trial credit amount in USD (default from config)
TRIAL_DAYS=                         # Trial duration in days (default from config)

# ═══ AUTOPILOT ═══
ENABLE_LEGACY_BACKEND_AUTOPILOT=    # "true" to enable legacy autopilot path
AUTOPILOT_TEST_PHONE=               # Phone number for autopilot testing
AUTOPILOT_WINDOW_START=             # Business hours start (default: 8)
AUTOPILOT_WINDOW_END=               # Business hours end (default: 22)
AUTOPILOT_SILENCE_HOURS=            # Hours of silence before re-engaging (default: 24)
AUTOPILOT_CYCLE_LIMIT=              # Max autopilot cycles (default: 200)
AUTOPILOT_CONTACT_DAILY_LIMIT=      # Max messages per contact per day (default: 5)
AUTOPILOT_WORKSPACE_DAILY_LIMIT=    # Max messages per workspace per day
AUTOPILOT_QUEUE_WAITING_THRESHOLD=  # Queue waiting threshold (default: 200)
AUTOPILOT_CONTACT_DEBOUNCE_MS=      # Contact debounce in ms (default: 2000)
AUTOPILOT_SHARED_REPLY_LOCK_MS=     # Shared reply lock TTL in ms (default: 45000)
AUTOPILOT_INLINE_REACTIVE=          # "true"/"false" for inline reactive mode (default: true)
AUTOPILOT_BYPASS_HUMAN_LOCK=        # "true" to bypass human lock
AUTOPILOT_RECLAIM_HUMAN_LOCK_ON_INBOUND= # Reclaim human lock on inbound (default: true)
AUTOPILOT_ENFORCE_24H=              # "true" to enforce 24h messaging window
AUTOPILOT_ALERT_WEBHOOK=            # Webhook URL for autopilot alerts
ENFORCE_OPTIN=                      # "true" to enforce opt-in before messaging

# ═══ CIA RUNTIME ═══
CIA_BOOTSTRAP_IMMEDIATE_LIMIT=      # Immediate bootstrap limit (default: 5)
CIA_BOOTSTRAP_REMOTE_LOOKBACK_MS=   # Remote lookback window in ms
CIA_REMOTE_PENDING_MAX_AGE_MS=      # Max age for remote pending items
CIA_REMOTE_UNKNOWN_PENDING_MAX_AGE_MS= # Max age for unknown pending items
CIA_INLINE_BACKLOG_FALLBACK_LIMIT=  # Inline backlog fallback limit (default: 10)
CIA_BOOTSTRAP_AUTO_CONTINUE=        # "true"/"false" for auto-continue (default: true)
CIA_BOOTSTRAP_AUTO_CONTINUE_LIMIT=  # Auto-continue limit (default: 500)
CIA_CONTACT_CATALOG_LOOKBACK_DAYS=  # Contact catalog lookback in days (default: 30)
CIA_RUNTIME_STALE_RUN_MS=           # Stale run threshold in ms (default: 10min)
CIA_PRESENCE_HEARTBEAT_MS=          # Presence heartbeat in ms (default: 25000)
CIA_BOOTSTRAP_INCLUDE_ZERO_UNREAD_ACTIVITY= # Include zero-unread activity (default: false)

# ═══ QUEUE / WORKERS ═══
QUEUE_ATTEMPTS=                     # Job retry attempts (default: 3)
QUEUE_BACKOFF_MS=                   # Job backoff delay in ms (default: 5000)
WORKER_HEALTH_CACHE_MS=             # Worker health cache TTL (default: 15000)
WORKER_HEALTH_TIMEOUT_MS=           # Worker health check timeout (default: 1500)

# ═══ MASS SEND ═══
MASS_SEND_JITTER_MIN_MS=            # Min jitter between mass sends (default: 5000)
MASS_SEND_JITTER_MAX_MS=            # Max jitter between mass sends (default: 15000)

# ═══ KNOWLEDGE BASE ═══
KB_FETCH_MAX_BYTES=                 # Max bytes when fetching URL content (default: 1MB)
KB_MAX_CHUNKS=                      # Max chunks for embeddings (default: 400)
KB_FETCH_TIMEOUT_MS=                # Fetch timeout in ms (default: 8000)
KB_URL_ALLOWLIST=                   # Comma-separated URL allowlist

# ═══ OBSERVABILITY ═══
SENTRY_DSN=                         # Sentry DSN for error tracking
SENTRY_TRACES_SAMPLE_RATE=          # Sentry trace sample rate (default: 0.1)
OPS_WEBHOOK_URL=                    # Ops alert webhook URL (Slack/Discord)
DLQ_WEBHOOK_URL=                    # Dead-letter queue alert webhook URL
AUDIT_WEBHOOK_URL=                  # Audit log webhook URL

# ═══ SECURITY / INTERNAL ═══
INTERNAL_API_KEY=                   # API key for internal service-to-service calls
SCREENCAST_SHARED_SECRET=           # Shared secret for screencast endpoints
SCREENCAST_TOKEN_TTL_SECONDS=       # Screencast token TTL in seconds (default: 120)
ENCRYPTION_KEY=                     # AES encryption key for sensitive data at rest
HOOKS_WEBHOOK_SECRET=               # HMAC secret for hooks webhook verification
DIAG_TOKEN=                         # Token for diagnostics endpoint (required in prod)
METRICS_TOKEN=                      # Token for metrics endpoint (required in prod)

# ═══ SWAGGER ═══
SWAGGER_BASIC_USER=                 # Basic auth username for Swagger UI (prod only)
SWAGGER_BASIC_PASS=                 # Basic auth password for Swagger UI (prod only)

# ═══ FEATURE FLAGS ═══
GUEST_CHAT_ENABLED=                 # Enable guest chat (default: "false" in prod, "true" in dev)
KLOEL_THINK_TIMEOUT_MS=             # Timeout for /kloel/think endpoint in ms (default: 60000)

# ═══ BUILD / DEPLOY ═══
RAILWAY_GIT_COMMIT_SHA=             # Git commit SHA (auto-set by Railway)
GIT_SHA=                            # Git commit SHA (manual override)
BUILD_TIMESTAMP=                    # Build timestamp
npm_package_version=                # Package version (auto-set by npm)
