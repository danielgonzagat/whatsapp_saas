{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "overrides": {
    "path-to-regexp": ">=8.4.0",
    "lodash": "4.18.1",
    "@tootallnate/once": "3.0.1"
  },
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "build": "nest build && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node -r ./dd-trace-init.cjs ./node_modules/@nestjs/cli/bin/nest.js start",
    "start:dev": "node -r ./dd-trace-init.cjs ./node_modules/@nestjs/cli/bin/nest.js start --watch",
    "start:debug": "node -r ./dd-trace-init.cjs ./node_modules/@nestjs/cli/bin/nest.js start --debug --watch",
    "start:prod": "node prisma/ensure-migrations.js && node -r ./dd-trace-init.cjs dist/src/bootstrap.js",
    "start:prod:migrate": "node prisma/ensure-migrations.js && node -r ./dd-trace-init.cjs dist/src/bootstrap.js",
    "prisma:migrate": "npx prisma migrate deploy",
    "prisma:generate": "npx prisma generate",
    "prisma:validate": "npx prisma validate",
    "prisma:status": "npx prisma migrate status",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:check": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "seed:products": "ts-node prisma/seed-products.ts",
    "seed:affiliates": "ts-node scripts/seed-affiliate-products.ts",
    "cleanup:legacy-products": "ts-node scripts/remove-legacy-products.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1040.0",
    "@aws-sdk/s3-request-presigner": "3.1040.0",
    "@nestjs-modules/ioredis": "2.2.1",
    "@nestjs/common": "11.1.19",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.19",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.19",
    "@nestjs/platform-socket.io": "11.1.19",
    "@nestjs/schedule": "6.1.3",
    "@nestjs/swagger": "11.4.2",
    "@nestjs/throttler": "6.5.0",
    "@nestjs/websockets": "11.1.19",
    "@prisma/client": "5.22.0",
    "@sentry/nestjs": "10.51.0",
    "@sentry/node": "10.51.0",
    "@types/bcrypt": "6.0.0",
    "@types/cookie-parser": "1.4.10",
    "@types/passport-jwt": "4.0.1",
    "bcrypt": "6.0.0",
    "bullmq": "5.76.4",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "dd-trace": "5.99.0",
    "dotenv": "17.4.2",
    "facebook-nodejs-business-sdk": "24.0.1",
    "firebase-admin": "13.8.0",
    "helmet": "8.1.0",
    "htmlparser2": "10.1.0",
    "ioredis": "5.10.1",
    "joi": "18.1.2",
    "openai": "6.35.0",
    "otplib": "12.0.1",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "pdf-parse": "2.4.5",
    "pino": "10.3.1",
    "prisma": "5.22.0",
    "prom-client": "15.1.3",
    "qrcode": "1.5.4",
    "raw-body": "3.0.2",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "socket.io": "4.8.3",
    "stripe": "22.1.0",
    "swagger-ui-express": "5.0.1",
    "zod": "4.4.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.3",
    "@eslint/js": "9.39.1",
    "@nestjs/cli": "11.0.18",
    "@nestjs/schematics": "11.0.10",
    "@nestjs/testing": "11.1.9",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/node": "22.19.1",
    "@types/qrcode": "1.5.6",
    "@types/supertest": "6.0.3",
    "eslint": "9.39.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.4",
    "eslint-seatbelt": "0.1.3",
    "fast-check": "4.6.0",
    "globals": "16.5.0",
    "ioredis-mock": "8.13.1",
    "jest": "30.2.0",
    "jest-junit": "16.0.0",
    "prettier": "3.7.3",
    "source-map-support": "0.5.21",
    "supertest": "7.1.4",
    "ts-jest": "29.4.9",
    "ts-loader": "9.5.4",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.48.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "reporters": [
      "default",
      [
        "jest-junit",
        {
          "outputDirectory": "./test-results",
          "outputName": "backend-junit.xml",
          "suiteName": "backend",
          "ancestorSeparator": " › ",
          "classNameTemplate": "{classname}",
          "titleTemplate": "{title}"
        }
      ]
    ],
    "testEnvironment": "node",
    "detectOpenHandles": true,
    "coverageThreshold": {
      "global": {
        "branches": 15,
        "functions": 18,
        "lines": 18,
        "statements": 18
      },
      "./src/common/decorators/": {
        "branches": 90,
        "functions": 90,
        "lines": 90,
        "statements": 90
      },
      "./src/common/guards/": {
        "branches": 90,
        "functions": 90,
        "lines": 90,
        "statements": 90
      },
      "./src/common/payment-state-machine.ts": {
        "branches": 80,
        "functions": 100,
        "lines": 100,
        "statements": 100
      },
      "./src/common/money.ts": {
        "branches": 80,
        "functions": 100,
        "lines": 90,
        "statements": 90
      },
      "./src/common/idempotency.guard.ts": {
        "branches": 50,
        "functions": 40,
        "lines": 75,
        "statements": 75
      },
      "./src/common/idempotency.interceptor.ts": {
        "branches": 50,
        "functions": 80,
        "lines": 80,
        "statements": 80
      },
      "./src/common/idempotency-fingerprint.ts": {
        "branches": 80,
        "functions": 100,
        "lines": 100,
        "statements": 100
      },
      "./src/common/pagination-clamp.pipe.ts": {
        "branches": 90,
        "functions": 100,
        "lines": 100,
        "statements": 100
      },
      "./src/kloel/wallet.service.ts": {
        "branches": 55,
        "functions": 65,
        "lines": 65,
        "statements": 65
      },
      "./src/kloel/wallet-ledger.service.ts": {
        "branches": 80,
        "functions": 100,
        "lines": 95,
        "statements": 95
      },
      "./src/kloel/llm-budget.service.ts": {
        "branches": 75,
        "functions": 100,
        "lines": 95,
        "statements": 95
      },
      "./src/inbox/inbox.service.ts": {
        "branches": 30,
        "functions": 30,
        "lines": 30,
        "statements": 30
      },
      "./src/checkout/checkout-payment.service.ts": {
        "branches": 30,
        "functions": 30,
        "lines": 40,
        "statements": 40
      },
      "./src/billing/payment-method.service.ts": {
        "branches": 40,
