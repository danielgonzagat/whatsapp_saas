    "bullmq": "^5.73.1",
    "cheerio": "^1.2.0",
    "ioredis": "^5.8.2",
    "mathjs": "^15.2.0",
    "nodemailer": "^8.0.5",
    "openai": "^6.33.0",
    "prom-client": "^15.1.3",
    "puppeteer": "^24.40.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "prisma": "^5.10.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^4.1.2"
