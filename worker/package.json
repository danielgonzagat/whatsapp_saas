{
  "name": "worker",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "scripts": {
    "start": "ts-node --transpile-only bootstrap.ts",
    "start:watch": "nodemon --watch . -e ts --exec \"ts-node --transpile-only bootstrap.ts\"",
    "build": "tsc",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start:prod": "node dist/bootstrap.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prisma:generate": "npx prisma generate --schema=prisma/schema.prisma",
    "prisma:validate": "npx prisma validate --schema=prisma/schema.prisma",
    "lint": "eslint . --fix",
    "lint:check": "eslint ."
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "@sentry/node": "10.51.0",
    "@types/puppeteer": "5.4.7",
    "axios": "1.15.2",
    "bullmq": "5.76.4",
    "cheerio": "1.2.0",
    "dd-trace": "5.98.0",
    "ioredis": "5.10.1",
    "mathjs": "15.2.0",
    "nodemailer": "8.0.7",
    "openai": "6.35.0",
    "prom-client": "15.1.3",
    "puppeteer": "24.42.0",
    "puppeteer-extra": "3.3.6",
    "puppeteer-extra-plugin-stealth": "2.11.2",
    "stripe": "22.1.0",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-seatbelt": "0.1.3",
    "globals": "16.5.0",
    "nodemon": "3.1.14",
    "prettier": "3.8.3",
    "prisma": "5.22.0",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.1",
    "vitest": "4.1.5"
  }
}
