# adm.kloel.com — environment variables.
# Copy to .env.local for development; Vercel project `kloel-admin` is the
# source of truth in production.

# Backend URL. In dev: http://localhost:3001/admin. In prod: https://<railway>/admin.
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:3001/admin

# Public app name.
NEXT_PUBLIC_APP_NAME=Kloel Admin

# Optional: Sentry DSN + source-map upload.
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
