    "auth",
    "checkout",
    "wallet",
    "billing",
    "kyc",
    "whatsapp-session"
  ],
  "criticalFlows": [
    "auth-login",
    "product-create",
    "checkout-payment",
    "wallet-withdrawal",
    "whatsapp-message-send"
  ],
  "invariants": [
    "workspace-isolation",
    "financial-audit-trail",
    "payment-idempotency",
    "wallet-balance-consistency"
  ],
  "flowSpecs": [
    {
      "id": "auth-login",
      "surface": "frontend-ui",
      "runner": "hybrid",
      "oracle": "auth-session",
      "providerMode": "hybrid",
      "smokeRequired": false,
      "critical": true,
      "preconditions": ["auth-flow-tester", "e2e-registration"],
      "environments": ["deep", "total"],
      "notes": "Login must authenticate, persist session, and land on the authenticated shell."
    },
    {
      "id": "product-create",
      "surface": "frontend-ui",
      "runner": "hybrid",
      "oracle": "entity-persisted",
      "providerMode": "hybrid",
      "smokeRequired": false,
      "critical": true,
      "preconditions": ["e2e-product-creation"],
      "environments": ["deep", "total"],
      "notes": "Product creation must persist backend state and reflect in product listing after reload."
    },
    {
      "id": "checkout-payment",
      "surface": "frontend-ui",
      "runner": "hybrid",
      "oracle": "payment-lifecycle",
      "providerMode": "hybrid",
      "smokeRequired": true,
      "critical": true,
      "preconditions": ["e2e-payment", "webhook-simulator"],
      "environments": ["deep", "total"],
      "notes": "Checkout must create order, payment intent, and survive webhook reconciliation."
    },
    {
      "id": "wallet-withdrawal",
      "surface": "frontend-ui",
      "runner": "hybrid",
      "oracle": "wallet-ledger",
      "providerMode": "hybrid",
      "smokeRequired": true,
      "critical": true,
      "preconditions": ["e2e-withdrawal", "concurrency-tester"],
      "environments": ["deep", "total"],
      "notes": "Withdrawal must persist safely with audit trail and balance consistency."
    },
    {
      "id": "whatsapp-message-send",
      "surface": "frontend-ui",
      "runner": "browser-stress",
      "oracle": "conversation-persisted",
      "providerMode": "hybrid",
